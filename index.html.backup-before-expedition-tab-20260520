function degToDir(deg){
  if(deg == null || isNaN(deg)) return '—';
  return DIR16[Math.round(deg / 22.5) % 16];
}
function wmoSky(c){ return WMO_SKY[c] || 'Variable'; }
function waveDesc(h){
  if(h == null || isNaN(h)) return 'Calm';
  if(h < 0.5) return 'Slight';
  if(h < 1.25) return 'Moderate';
  if(h < 2.5) return 'Rough';
  return 'Very rough';
}
function validVals(arr, idxs = null){
  const source = idxs ? idxs.map(i => arr?.[i]) : (arr || []);
  return source.filter(x => x != null && !isNaN(x));
}
function avgValue(arr, idxs = null){
  const v = validVals(arr, idxs);
  return v.length ? v.reduce((a, b) => a + b, 0) / v.length : null;
}
function minValue(arr, idxs = null){
  const v = validVals(arr, idxs);
  return v.length ? Math.min(...v) : null;
}
function maxValue(arr, idxs = null){
  const v = validVals(arr, idxs);
  return v.length ? Math.max(...v) : null;
}
function windDirMean(arr, idxs = null){
  const v = validVals(arr, idxs);
  if(!v.length) return null;
  const sx = v.reduce((a, d) => a + Math.sin(d * Math.PI / 180), 0) / v.length;
  const cx = v.reduce((a, d) => a + Math.cos(d * Math.PI / 180), 0) / v.length;
  return ((Math.atan2(sx, cx) * 180 / Math.PI) + 360) % 360;
}
function modeValue(arr, idxs = null){
  const v = validVals(arr, idxs);
  if(!v.length) return null;
  const freq = {};
  v.forEach(x => { freq[x] = (freq[x] || 0) + 1; });
  return Object.keys(freq).reduce((a, b) => freq[b] > freq[a] ? b : a);
}
function fmtRange(min, max, unit = ''){
  if(min == null || max == null) return '—';
  const a = Math.round(min);
  const b = Math.round(max);
  return a === b ? `${a}${unit}` : `${a}–${b}${unit}`;
}
function fmtFixedRange(min, max, unit = '', digits = 1){
  if(min == null || max == null) return '—';
  const a = Number(min).toFixed(digits);
  const b = Number(max).toFixed(digits);
  return a === b ? `${a}${unit}` : `${a}–${b}${unit}`;
}
function fmtRain(value, mode = ''){
  if(value == null || isNaN(value)) return '—';
  const n = Number(value);
  const text = n < 10 ? n.toFixed(1) : Math.round(n).toString();
  return `${text} ${mode === 'rate' ? 'mm/h' : 'mm'}`;
}
const WIND_SPEED_SCALE = [
  { kt: 0, h: 196, s: 55, l: 42 },
  { kt: 6, h: 164, s: 55, l: 36 },
  { kt: 12, h: 86, s: 48, l: 38 },
  { kt: 18, h: 44, s: 76, l: 43 },
  { kt: 24, h: 27, s: 78, l: 47 },
  { kt: 30, h: 5, s: 62, l: 48 },
  { kt: 38, h: 326, s: 45, l: 45 },
  { kt: 48, h: 270, s: 42, l: 43 },
];
function windSpeedColor(value){
  if(value == null || isNaN(value)) return '';
  const n = Math.max(0, Number(value));
  const scale = WIND_SPEED_SCALE;
  if(n <= scale[0].kt) return `hsl(${scale[0].h} ${scale[0].s}% ${scale[0].l}%)`;
  for(let i = 1; i < scale.length; i++){
    const prev = scale[i - 1];
    const next = scale[i];
    if(n <= next.kt){
      const t = (n - prev.kt) / (next.kt - prev.kt);
      const hDelta = ((next.h - prev.h + 540) % 360) - 180;
      const h = Math.round((prev.h + hDelta * t + 360) % 360);
      const s = Math.round(prev.s + (next.s - prev.s) * t);
      const l = Math.round(prev.l + (next.l - prev.l) * t);
      return `hsl(${h} ${s}% ${l}%)`;
    }
  }
  const last = scale[scale.length - 1];
  return `hsl(${last.h} ${last.s}% ${last.l}%)`;
}
function windSpeedStyle(value){
  const color = windSpeedColor(value);
  return color ? ` style="--wind-col:${color}"` : '';
}
function windSpeedValueHtml(text, value){
  return `<span class="wind-speed-val"${windSpeedStyle(value)}>${escapeHtml(text)}</span>`;
}
function capeClass(cape){
  if(cape == null || isNaN(cape)) return 'cape-low';
  if(cape >= 1000) return 'cape-high';
  if(cape >= 500) return 'cape-active';
  if(cape >= 200) return 'cape-watch';
  return 'cape-low';
}
function capeLabel(cape){
  if(cape == null || isNaN(cape)) return 'Unavailable';
  if(cape >= 1000) return 'High instability';
  if(cape >= 500) return 'Active instability';
  if(cape >= 200) return 'Watch';
  return 'Low';
}
function uvLabel(uv){
  if(uv == null || isNaN(uv)) return 'Unavailable';
  if(uv >= 8) return 'Very high';
  if(uv >= 6) return 'High';
  if(uv >= 3) return 'Moderate';
  return 'Low';
}
function fmt12(t){
  const [h, m] = t.split(':');
  const hr = parseInt(h, 10);
  const ap = hr >= 12 ? 'pm' : 'am';
  const h12 = hr % 12 || 12;
  return m === '00' ? `${h12}${ap}` : `${h12}:${m}${ap}`;
}
function fmtDate(iso){
  const d = new Date(iso + 'T00:00:00');
  const days = ['Sun','Mon','Tues','Wed','Thurs','Fri','Sat'];
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}
