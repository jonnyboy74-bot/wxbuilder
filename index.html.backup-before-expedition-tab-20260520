    <button type="button" id="squidGribBtn" class="btn btn-squid" onclick="loadSquidGrib()">Load Squid GRIB</button>
  </section>

  <section>
    <button id="fetchBtn" type="button" class="btn btn-primary" style="width:100%" onclick="fetchSelectedSource()">Load GRIB period brief</button>
    <button id="supplementOmBtn" type="button" class="btn btn-ghost" style="width:100%;font-size:var(--xs);margin-top:var(--s2);display:none" onclick="supplementForecastFromOpenMeteo()">Supplement CAPE/rain (Open-Meteo ECMWF)</button>
    <button id="teamCopyBtn" type="button" class="btn btn-ghost" style="width:100%;font-size:var(--xs);margin-top:var(--s2)" onclick="copyTeamBrief()">Copy team brief</button>
