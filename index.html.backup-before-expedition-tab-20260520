async function copyTeamBrief(){
  const text = document.getElementById('teamBriefText')?.value || buildTeamBriefText();
  try {
    await navigator.clipboard.writeText(text);
    setStatus('green', 'Team brief copied to clipboard.');
  } catch {
    window.prompt('Copy team brief', text);
    setStatus('yellow', 'Copy manually from the prompt.');
  }
}

