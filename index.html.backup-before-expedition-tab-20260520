function buildTeamBriefText(){
  const vessel = document.getElementById('vesselName')?.value.trim() || 'Vessel';
  const eventName = document.getElementById('eventName')?.value.trim() || '';
  const raceDay = document.getElementById('raceDay')?.value.trim() || '';
  const venue = document.getElementById('venueInput').value || 'Venue';
  const dateVal = document.getElementById('fDate').value;
  const model = document.getElementById('briefingModel').value;
  const modelLabel = gribSourceLabel || openMeteoModelLabel(model) || 'Auto';
  const title = [vessel, eventName, raceDay, venue].filter(Boolean).join(' · ');
  const lines = [
    title,
    dateVal ? fmtDate(dateVal) : '',
    modelLabel,
    buildBriefSourceNote(),
  ].filter(Boolean);

  if(!forecastData){
    lines.push('No forecast loaded yet.');
    return lines.join('\n');
  }

  const trend = trendSummary(briefingTrendIndices());
  lines.push(trendSummaryText(trend));

  PERIODS.filter(p => activePeriods.has(p.id)).forEach(p => {
    const d = sliceHours(p.from, p.to);
    if(!d) return;
    const twd = d.twdDeg == null ? 'TWD —' : `TWD ${d.twdStr} ${Math.round(d.twdDeg)}°`;
    const tws = `TWS ${fmtRange(d.twsMin, d.twsMax, ' kt')}`;
    const gust = d.gust == null ? 'gust —' : `gust ${Math.round(d.gust)} kt`;
    const temp = d.tempMin != null && d.tempMax != null ? `temp ${fmtRange(d.tempMin, d.tempMax, '°C')}` : '';
    const rain = d.rain == null ? '' : `rain ${fmtRain(d.rain, forecastMeta?.rainMode)}`;
    const cape = d.capeMax == null ? '' : `CAPE ${Math.round(d.capeMax)} J/kg`;
    const uv = d.uvMax == null ? '' : `UV ${Math.round(d.uvMax)}`;
    const wave = d.waveH == null && d.waveDir == null
      ? ''
      : `Sig Wave ${d.waveH == null ? '—' : `${d.waveH.toFixed(1)} m`}${d.waveDir == null ? '' : ` · Wave Direction ${d.waveDirStr} ${Math.round(d.waveDir)}°`}`;
    const sky = d.sky && d.sky !== 'Variable' ? d.sky : '';
    lines.push(`${p.name} ${fmt12(p.from)}-${fmt12(p.to)}: ${[twd, tws, gust, temp, sky, rain, cape, uv, wave].filter(Boolean).join(' · ')}`);
  });

  return lines.join('\n');
}

function buildTeamBriefVisual(){
  const vessel = document.getElementById('vesselName')?.value.trim() || 'Vessel';
  const eventName = document.getElementById('eventName')?.value.trim() || '';
  const raceDay = document.getElementById('raceDay')?.value.trim() || '';
  const venue = document.getElementById('venueInput').value || 'Venue';
  const dateVal = document.getElementById('fDate').value;
  const model = document.getElementById('briefingModel').value;
  const modelLabel = gribSourceLabel || openMeteoModelLabel(model) || 'Auto';
  const sourceNote = buildBriefSourceNote() || (gribSourceLabel ? 'Squid GRIB' : 'Open-Meteo · Europe/Rome');
  const lat = parseFloat(document.getElementById('latInput').value);
  const lon = parseFloat(document.getElementById('lonInput').value);
  const coordMeta = (!isNaN(lat) && !isNaN(lon))
    ? `${Math.abs(lat).toFixed(3)}°${lat >= 0 ? 'N' : 'S'} ${Math.abs(lon).toFixed(3)}°${lon >= 0 ? 'E' : 'W'} · `
    : '';

  let html = forecastData
    ? renderDailyOverview(modelLabel, sourceNote, coordMeta, venue, dateVal, '', vessel, eventName, raceDay)
    : `<div class="f-header">
    <div class="f-venue">${escapeHtml(vessel)}</div>
    ${dateVal ? `<div class="f-date">${fmtDate(dateVal)}</div>` : ''}
    <div class="f-meta">${[eventName, raceDay, venue, modelLabel].filter(Boolean).map(escapeHtml).join(' · ')}</div>
  </div>`;

  if(!forecastData){
    return html + '<div class="empty" style="padding:var(--s4)">Load a forecast to generate team brief.</div>';
  }

  html += '<div class="team-period-grid">';
  PERIODS.filter(p => activePeriods.has(p.id)).forEach((p, idx) => {
    const d = sliceHours(p.from, p.to);
    const cls = 'pcard c' + Math.min(idx, 5);
    if(!d) return;
    const twd = d.twdDeg == null ? 'TWD —' : `TWD <strong>${d.twdStr}</strong> ${Math.round(d.twdDeg)}°`;
    const tws = `TWS ${windSpeedValueHtml(fmtRange(d.twsMin, d.twsMax, ' kt'), d.twsMax)}`;
    const gust = d.gust == null ? 'gust —' : `gust ${windSpeedValueHtml(`${Math.round(d.gust)} kt`, d.gust)}`;
    const temp = d.tempMin != null && d.tempMax != null ? fmtRange(d.tempMin, d.tempMax, '°C') : '—';
    const sky = d.sky && d.sky !== 'Variable' ? escapeHtml(d.sky) : '—';
    const rain = d.rain == null ? 'Rain —' : `Rain ${fmtRain(d.rain, forecastMeta?.rainMode)}`;
    const cape = d.capeMax == null ? 'CAPE —' : `CAPE <span class="cape-pill ${capeClass(d.capeMax)}">${Math.round(d.capeMax)} J/kg</span>`;
    const sea = d.waveH == null && d.waveDir == null
      ? 'Sig Wave —'
      : `Sig Wave <strong>${d.waveH == null ? '—' : `${d.waveH.toFixed(1)} m`}</strong>${d.waveDir == null ? '' : ` · Wave Direction <strong>${d.waveDirStr}</strong> ${Math.round(d.waveDir)}°`}`;
    html += `<article class="${cls}">
      <div class="pt-row"><span class="pt-name">${p.name}</span><span class="pt-time">${fmt12(p.from)} – ${fmt12(p.to)}</span></div>
      <div class="frow">${briefIcon('wind')}<span>${twd} · ${tws} · ${gust}</span></div>
      <div class="frow">${briefIcon('temp')}<span>${temp}</span></div>
      <div class="frow">${briefIcon('sky')}<span>${sky}</span></div>
      <div class="frow">${briefIcon('rain')}<span>${rain}</span></div>
      <div class="frow">${briefIcon('cape')}<span>${cape}</span></div>
      <div class="frow">${briefIcon('sea')}<span>${sea}</span></div>
    </article>`;
  });
  html += '</div>';
  return html;
}

function updateTeamBriefPreview(){
  const textEl = document.getElementById('teamBriefText');
  if(textEl && document.activeElement !== textEl) textEl.value = buildTeamBriefText();
