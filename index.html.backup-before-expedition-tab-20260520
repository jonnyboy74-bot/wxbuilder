<script>
const PERIODS = [
  { id:'dawn',    name:'Dawn',      from:'04:00', to:'07:00' },
  { id:'early',   name:'Early',     from:'07:00', to:'09:00' },
  { id:'morning', name:'Morning',   from:'09:00', to:'12:00' },
  { id:'midday',  name:'Midday',    from:'12:00', to:'15:00' },
  { id:'aftn',    name:'Afternoon', from:'15:00', to:'18:00' },
  { id:'evening', name:'Evening',   from:'18:00', to:'21:00' },
];
const ACTIVE_DEFAULT = ['early','morning','midday','aftn'];
const TREND_PERIOD_IDS = ['morning', 'midday', 'aftn'];
const TREND_WINDOW_LABEL = '09:00–18:00';
const TREND_BIG_TWD_DEG = 15;
const TREND_BIG_TWS_KT = 3;
const TREND_MAX_PER_FIELD = 2;
const DIR16 = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
const WMO_SKY = {
  0:'Clear sky',1:'Mainly clear',2:'Partly cloudy',3:'Overcast',
  45:'Foggy',48:'Rime fog',
  51:'Light drizzle',53:'Drizzle',55:'Heavy drizzle',
  61:'Light rain',63:'Rain',65:'Heavy rain',
  80:'Showers',81:'Showers',82:'Heavy showers',
  95:'Thunderstorm',96:'Thunderstorm + hail',99:'Thunderstorm + hail'
};
// European Open-Meteo model pack (Caribbean regional models to be added later).
const OPENMETEO_EUROPE_MODELS = [
  { id:'best_match', label:'Best match', group:'Auto', provider:'Open-Meteo', resolution:'auto', base:'https://api.open-meteo.com/v1/forecast', param:'', maxDays:16, briefing:true, compare:false },
  { id:'ecmwf_ifs', label:'ECMWF IFS HRES', group:'ECMWF', provider:'ECMWF', resolution:'9 km', base:'https://api.open-meteo.com/v1/ecmwf', param:'&models=ecmwf_ifs', maxDays:15, note:'CAPE · native 9 km IFS', briefing:true, compare:true, defaultBriefing:true },
  { id:'ecmwf_ifs025', label:'ECMWF IFS open-data', group:'ECMWF', provider:'ECMWF', resolution:'25 km', base:'https://api.open-meteo.com/v1/ecmwf', param:'&models=ecmwf_ifs025', maxDays:15, briefing:true, compare:true },
  { id:'ecmwf_aifs025', label:'ECMWF AIFS', group:'ECMWF', provider:'ECMWF AI', resolution:'28 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=ecmwf_aifs025', maxDays:15, note:'AI model · 6-hourly native', briefing:true, compare:true },
  { id:'icon_seamless', label:'ICON Seamless', group:'DWD ICON', provider:'DWD', resolution:'2–11 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=icon_seamless', maxDays:7, briefing:true, compare:true },
  { id:'icon_global', label:'ICON Global', group:'DWD ICON', provider:'DWD', resolution:'11 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=icon_global', maxDays:7, briefing:true, compare:true },
  { id:'icon_eu', label:'ICON-EU', group:'DWD ICON', provider:'DWD', resolution:'7 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=icon_eu', maxDays:5, briefing:true, compare:true },
  { id:'icon_d2', label:'ICON-D2', group:'DWD ICON', provider:'DWD', resolution:'2 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=icon_d2', maxDays:2, domainMsg:'ICON-D2 covers central Europe only. This position may be outside the model domain.', briefing:true, compare:true },
  { id:'meteofrance_seamless', label:'MF Seamless', group:'Météo-France', provider:'Météo-France', resolution:'1.5–25 km', base:'https://api.open-meteo.com/v1/meteofrance', param:'&models=meteofrance_seamless', maxDays:4, briefing:true, compare:true },
  { id:'meteofrance_arpege_europe', label:'ARPEGE Europe', group:'Météo-France', provider:'Météo-France', resolution:'11 km', base:'https://api.open-meteo.com/v1/meteofrance', param:'&models=meteofrance_arpege_europe', maxDays:4, domainMsg:'ARPEGE Europe: no data at this position.', briefing:true, compare:true },
  { id:'meteofrance_arome_france', label:'AROME France', group:'Météo-France', provider:'Météo-France', resolution:'2.5 km', base:'https://api.open-meteo.com/v1/meteofrance', param:'&models=meteofrance_arome_france', maxDays:2, domainMsg:'AROME France covers France and nearby areas only.', briefing:true, compare:true },
  { id:'meteofrance_arome_france_hd', label:'AROME HD', group:'Météo-France', provider:'Météo-France', resolution:'1.5 km', base:'https://api.open-meteo.com/v1/meteofrance', param:'&models=meteofrance_arome_france_hd', maxDays:2, domainMsg:'AROME HD covers France only. This position is outside the model domain.', briefing:true, compare:true },
  { id:'italia_meteo_arpae_icon_2i', label:'ICON-2i', group:'Italy', provider:'ItaliaMeteo ARPAE', resolution:'2 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=italia_meteo_arpae_icon_2i', maxDays:3, domainMsg:'ICON-2i covers Italy and nearby areas. This position may be outside the model domain.', briefing:true, compare:true },
  { id:'ukmo_seamless', label:'UKMO Seamless', group:'UK Met Office', provider:'UKMO', resolution:'2–10 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=ukmo_seamless', maxDays:7, briefing:true, compare:true },
  { id:'ukmo_global_deterministic_10km', label:'UKMO Global 10 km', group:'UK Met Office', provider:'UKMO', resolution:'10 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=ukmo_global_deterministic_10km', maxDays:7, briefing:true, compare:true },
  { id:'metno_nordic_seamless', label:'MET Nordic', group:'Nordics', provider:'MET Norway', resolution:'1 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=metno_nordic_seamless', maxDays:2, domainMsg:'MET Nordic has a short forecast range (~2.5 days).', briefing:true, compare:true },
  { id:'knmi_harmonie_arome_europe', label:'KNMI Harmonie', group:'Nordics', provider:'KNMI', resolution:'2 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=knmi_harmonie_arome_europe', maxDays:2, briefing:true, compare:true },
  { id:'dmi_harmonie_arome_europe', label:'DMI Harmonie', group:'Nordics', provider:'DMI', resolution:'2 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=dmi_harmonie_arome_europe', maxDays:2, briefing:true, compare:true },
  { id:'meteoswiss_icon_ch1', label:'MeteoSwiss ICON CH1', group:'Switzerland', provider:'MeteoSwiss', resolution:'1 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=meteoswiss_icon_ch1', maxDays:5, domainMsg:'MeteoSwiss ICON CH covers Switzerland and nearby Alps.', briefing:true, compare:true },
  { id:'meteoswiss_icon_ch2', label:'MeteoSwiss ICON CH2', group:'Switzerland', provider:'MeteoSwiss', resolution:'2 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=meteoswiss_icon_ch2', maxDays:5, domainMsg:'MeteoSwiss ICON CH covers Switzerland and nearby Alps.', briefing:true, compare:true },
  { id:'gfs_seamless', label:'GFS Seamless', group:'Global', provider:'NOAA', resolution:'3–25 km', base:'https://api.open-meteo.com/v1/forecast', param:'&models=gfs_seamless', maxDays:16, briefing:true, compare:true },
];
const OPENMETEO_MODEL_ALIASES = {
  best:'best_match', ecmwf:'ecmwf_ifs', icon:'icon_eu', gfs:'gfs_seamless',
  arpege:'meteofrance_arpege_europe', arome_hd:'meteofrance_arome_france_hd', icon_2i:'italia_meteo_arpae_icon_2i',
};
const OPENMETEO_MODEL_BY_ID = Object.fromEntries(OPENMETEO_EUROPE_MODELS.map(m => [m.id, m]));
function resolveOpenMeteoModelId(id){ return OPENMETEO_MODEL_ALIASES[id] || id; }
function getOpenMeteoModel(id){ return OPENMETEO_MODEL_BY_ID[resolveOpenMeteoModelId(id)] || null; }
function openMeteoModelLabel(id){
  const m = getOpenMeteoModel(id);
  return m ? `${m.label} · ${m.resolution}` : 'Open-Meteo';
}

const OPENMETEO_META_BASE = 'https://openmeteo.s3.amazonaws.com/data';
const HYBRID_OM_MODEL_ID = 'ecmwf_ifs';

function openMeteoMetadataSlug(cfg){
  if(cfg?.metadataSlug) return cfg.metadataSlug;
  const m = String(cfg?.param || '').match(/models=([^&]+)/);
  if(m) return decodeURIComponent(m[1]);
  if(cfg?.base?.includes('/ecmwf')) return cfg.id && cfg.id.startsWith('ecmwf') ? cfg.id : HYBRID_OM_MODEL_ID;
  return cfg?.id || '';
}

async function fetchOpenMeteoRunMeta(slug){
  if(!slug) return null;
  try {
    const res = await fetch(`${OPENMETEO_META_BASE}/${slug}/static/meta.json`);
    if(!res.ok) return null;
    return res.json();
  } catch {
    return null;
  }
}

function formatUnixUtcRun(unix){
  if(unix == null || isNaN(unix)) return '';
  const d = new Date(Number(unix) * 1000);
  const y = d.getUTCFullYear();
  const mo = String(d.getUTCMonth() + 1).padStart(2, '0');
  const da = String(d.getUTCDate()).padStart(2, '0');
  const hh = String(d.getUTCHours()).padStart(2, '0');
  return `${y}-${mo}-${da} ${hh}:00z`;
}

function seriesHasValues(arr){
  return Array.isArray(arr) && arr.some(v => v != null && !isNaN(v));
}

function buildBriefSourceNote(){
  if(!forecastData) return '';
  if(forecastMeta?.source === 'Squid GRIB'){
    const gribLabel = gribSourceLabel || 'Squid GRIB';
    const parts = [`Wind: ${gribLabel}`];
    const fs = forecastMeta.fieldSources || {};
    if(fs.cape) parts.push(`CAPE: ${fs.cape}`);
    if(fs.rain) parts.push(`Rain: ${fs.rain}`);
    if(fs.uv) parts.push(`UV: ${fs.uv}`);
    if(fs.wave) parts.push(`Sig Wave: ${fs.wave}`);
    if(fs.temp) parts.push(`Temp: ${fs.temp}`);
    if(fs.sky) parts.push(`Sky: ${fs.sky}`);
    return parts.join(' · ');
  }
  return `Open-Meteo · ${openMeteoModelLabel(forecastMeta?.model || document.getElementById('briefingModel')?.value)}`;
}

