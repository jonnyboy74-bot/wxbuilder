function setPosition(lat, lon, opts = {}){
  lat = Math.round(lat * 1000) / 1000;
  lon = Math.round(lon * 1000) / 1000;
  document.getElementById('latInput').value = lat;
  document.getElementById('lonInput').value = lon;
  updateCoordReadout(lat, lon);
  if(venueMarker) venueMarker.setLatLng([lat, lon]);
  if(venueMap && opts.pan !== false) venueMap.panTo([lat, lon]);
  if(!opts.skipPresetClear){
    document.getElementById('venuePreset').value = '';
