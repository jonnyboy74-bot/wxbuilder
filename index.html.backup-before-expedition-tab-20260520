  if(!modelCfg?.maxDays) return;
  const limit = new Date();
  limit.setHours(12, 0, 0, 0);
  limit.setDate(limit.getDate() + Math.floor(modelCfg.maxDays));
  if(new Date(targetDate + 'T12:00:00') > limit){
    throw new Error(`${modelCfg.label} has a ${modelCfg.maxDays}-day forecast limit. Choose an earlier date.`);
  }
}
