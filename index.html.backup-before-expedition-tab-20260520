  comparisonSkippedGribs = [];
  comparisonSelectedHour = null;
  comparisonTimelineBaseDate = null;
  const status = document.getElementById('compareStatus');
  if(status) status.textContent = `Fetch ${comparisonSourceLabel(source)} comparison for current location/date.`;
  renderComparison();
}

const OPENMETEO_COMPARE_MODELS = OPENMETEO_EUROPE_MODELS
  .filter(m => m.compare)
  .map(m => ({
    id: m.id,
    label: m.label,
    detail: m.provider,
    resolution: m.resolution,
    base: m.base,
    param: m.param,
    source: 'open-meteo',
    note: m.note,
  }));
const COMPARE_MODEL_CONFIGS = [
  ...OPENMETEO_COMPARE_MODELS,
  { id:'lamma', label:'LaMMA', detail:'Squid GRIB local', resolution:'1 km', source:'local-grib' },
];
let comparisonConfigs = COMPARE_MODEL_CONFIGS;

function isLammaGribMeta(meta){
  const text = [meta?.modelLabel, meta?.file, meta?.name].filter(Boolean).join(' ').toLowerCase();
  return text.includes('lamma');
}

async function openMeteoCompareMeta(cfg, data, loadedAt){
  const slug = openMeteoMetadataSlug(cfg);
  const metaJson = await fetchOpenMeteoRunMeta(slug);
  const run = formatUnixUtcRun(metaJson?.last_run_initialisation_time);
  const apiLive = formatUnixUtcRun(metaJson?.last_run_availability_time);
  return {
    resolution: cfg.resolution,
    dataResolution: 'Hourly',
    run,
    runFallback: run ? '' : 'Run metadata unavailable',
    omAvailable: apiLive ? `API live ${apiLive}` : '',
    apiGeneration: formatApiGeneration(data?.generationtime_ms),
    loadedAt,
  };
}

function localLammaComparison(cfg){
  const meta = forecastMeta || {};
  const loadedAt = meta.source === 'Squid GRIB' && isLammaGribMeta(meta) ? (meta.loadedAt || '') : '';
  if(meta.source !== 'Squid GRIB' || !isLammaGribMeta(meta)){
    return {
      cfg,
      error: 'Load a LaMMA Squid GRIB file to compare local 1 km data.',
      readiness: 'Available via Squid GRIB source when a LaMMA file is loaded.',
      metadata: { resolution: cfg.resolution, dataResolution: 'Hourly GRIB', run: '', loadedAt },
    };
  }
  if(!forecastData?.hours?.length){
    return { cfg, error: 'LaMMA GRIB loaded but no hourly data is available.' };
  }
  return {
    cfg,
    hours: forecastData.hours,
    tws: forecastData.tws,
    twd: forecastData.twd,
    gust: forecastData.gust,
    temp: forecastData.temp,
    wmo: forecastData.wmo,
    cape: forecastData.cape,
    rain: forecastData.rain,
    wave: forecastData.wave,
    waveDir: forecastData.waveDir,
    metadata: {
      resolution: meta.fileResolutionLabel ? `File resolution ${meta.fileResolutionLabel}` : `File resolution ${cfg.resolution || 'unknown'}`,
      dataResolution: 'Hourly GRIB',
      run: formatRunTime(meta),
      loadedAt,
      file: meta.file || '',
      rainMode: meta.rainMode || '',
    },
  };
}

function compareMetaHtml(model){
  const meta = model?.metadata || {};
  const parts = [
    { value: compareResolutionText(meta.resolution), emphasize: true },
    meta.run ? { label: 'Run ', value: meta.run, emphasize: true } : (meta.runFallback ? { value: meta.runFallback } : null),
    meta.omAvailable ? { value: meta.omAvailable } : null,
    meta.apiGeneration ? { label: 'API gen ', value: meta.apiGeneration } : null,
    meta.loadedAt ? { label: 'Loaded ', value: formatLoadedTime(meta.loadedAt), emphasize: true } : null,
  ].filter(p => p?.value);
  return parts.length ? `<div class="compare-meta">${parts.map(p => `<span>${escapeHtml(p.label || '')}${p.emphasize ? `<strong>${escapeHtml(p.value)}</strong>` : escapeHtml(p.value)}</span>`).join('')}</div>` : '';
}

function compareModelHeaderHtml(cfg, model){
  const detail = cfg.detail && !/\bGRIB\b/i.test(cfg.detail) ? `<span class="compare-badge">${escapeHtml(cfg.detail)}</span>` : '';
  const headerModel = {
    ...(model || {}),
    metadata: {
      ...(model?.metadata || {}),
      resolution: model?.metadata?.resolution || cfg.resolution || '',
    },
  };
  return `<div class="compare-model-row">
    <div class="compare-model-main">
      <div class="compare-model">${escapeHtml(cfg.label)}</div>
      ${detail}
      ${compareMetaHtml(headerModel)}
    </div>
  </div>`;
}

function cleanGribLabel(label){
  return String(label || 'GRIB')
    .replace(/\s*\(Squid GRIB\)\s*/i, '')
    .trim() || 'GRIB';
}

function skippedGribLabel(item){
  if(item?.modelLabel) return cleanGribLabel(item.modelLabel);
  const file = String(item?.file || '').toLowerCase();
  if(file.includes('wam') || file.includes('mfwam')) return 'WAM';
  if(file.includes('ecmwf') || file.includes('ifs')) return 'ECMWF';
  if(file.includes('gfs')) return 'GFS';
  if(file.includes('icon')) return 'ICON';
  if(file.includes('lamma')) return file.includes('0_01') || file.includes('1km') ? 'LaMMA 1 km' : 'LaMMA';
  if(file.includes('arome')) return 'AROME';
  if(file.includes('arpege')) return 'ARPEGE';
  return 'GRIB';
}

function skippedGribReason(item){
  const err = String(item?.error || '').trim();
  if(/no wind data|windSampleCount/i.test(err)) return 'no usable TWS/TWD at selected location';
  if(/no usable TWS\/TWD or wave data/i.test(err)) return 'no usable TWS/TWD or wave data at selected location';
  if(/no usable TWS\/TWD, rain, CAPE, or wave data/i.test(err)) return 'no usable TWS/TWD, rain, CAPE, or wave data at selected location';
  return err || 'no usable data at selected location';
}

function groupedSkippedGribs(items){
  const grouped = new Map();
  (items || []).forEach(item => {
    const label = skippedGribLabel(item);
    const reason = skippedGribReason(item);
    const key = `${label}::${reason}`;
    if(!grouped.has(key)){
      grouped.set(key, { label, reason });
    }
  });
  return Array.from(grouped.values());
}

function gribCompareId(payload, i){
  const file = payload?.meta?.file || `bundle-${i + 1}`;
  const slug = String(file).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  return `grib-${i}-${slug || `bundle-${i + 1}`}`;
}

function gribCompareConfig(payload, i){
  const meta = payload?.meta || {};
  const label = cleanGribLabel(meta.modelLabel || 'Squid GRIB');
  const fields = Array.isArray(meta.availableFields) ? meta.availableFields : [];
  const hasWind = fields.includes('TWS') || fields.includes('TWD');
  const hasWave = fields.some(field => String(field).toLowerCase().includes('wave'));
  return {
    id: gribCompareId(payload, i),
    label,
    detail: hasWave && !hasWind ? 'Wave GRIB' : 'GRIB',
    resolution: meta.fileResolutionLabel || '',
  };
}

function gribBundleWindow(models){
  let start = null;
  models.forEach(payload => {
    (payload?.hours || []).forEach(hour => {
      const n = Number(hour);
      if(!isNaN(n)) start = start == null ? n : Math.min(start, n);
    });
  });
  return start == null ? null : { start, end: start + COMPARE_GRIB_MAX_HOURS };
}

function capGribPayloadToWindow(payload, timeWindow){
  const hours = payload?.hours || [];
  let idxs = hours
    .map((hour, i) => ({ hour: Number(hour), i }))
    .filter(item => !isNaN(item.hour));
  if(timeWindow){
    idxs = idxs.filter(item => item.hour >= timeWindow.start && item.hour < timeWindow.end);
  }
  idxs = idxs.sort((a, b) => a.hour - b.hour).slice(0, COMPARE_GRIB_MAX_HOURS).map(item => item.i);
  if(!idxs.length){
    idxs = hours.slice(0, COMPARE_GRIB_MAX_HOURS).map((_, i) => i);
  }
  const pick = arr => Array.isArray(arr) ? idxs.map(i => arr[i] ?? null) : idxs.map(() => null);
  return {
    hours: idxs.map(i => hours[i]),
    tws: pick(payload?.tws),
    twd: pick(payload?.twd),
    gust: pick(payload?.gust),
    temp: pick(payload?.temp),
    wmo: pick(payload?.wmo),
    cape: pick(payload?.cape),
    rain: pick(payload?.rain),
    wave: pick(payload?.wave),
    waveDir: pick(payload?.waveDir),
  };
}

function gribBundleComparison(payload, cfg, loadedAt, timeWindow){
  const meta = payload?.meta || {};
  const capped = capGribPayloadToWindow(payload, timeWindow);
  const hours = capped.hours;
  return {
    cfg,
    hours,
    tws: capped.tws,
    twd: capped.twd,
    gust: capped.gust,
    temp: capped.temp,
    wmo: capped.wmo,
    cape: capped.cape,
    rain: capped.rain,
    wave: capped.wave,
    waveDir: capped.waveDir,
    metadata: {
      resolution: cfg.resolution,
      run: formatRunTime(meta),
      loadedAt,
      rainMode: meta.rainMode || '',
    },
  };
}

async function readApiJson(res, label){
  const text = await res.text();
  let data = null;
  if(text){
    try {
      data = JSON.parse(text);
    } catch {
      const type = res.headers.get('content-type') || 'unknown content';
      const hint = type.includes('text/html')
        ? 'API route returned HTML. Restart Start Weather Brief.command so weather_brief_server.py serves the GRIB bundle endpoint.'
        : `API route returned ${type}.`;
      throw new Error(`${label} returned non-JSON HTTP ${res.status}. ${hint}`);
    }
  }
  if(!res.ok) throw new Error(data?.error || `${label} HTTP ${res.status}`);
  return data || {};
}

async function fetchGribBundleComparison(lat, lon, loadedAt, dateVal){
  if(location.protocol === 'file:'){
    throw new Error('Open Weather Brief via Start Weather Brief.command to use the GRIB bundle.');
  }
  const url = new URL('/api/squid-grib-bundle', window.location.origin);
  url.searchParams.set('lat', String(lat));
  url.searchParams.set('lon', String(lon));
  url.searchParams.set('_', String(Date.now()));
  const res = await fetch(url.toString(), { headers: { Accept: 'application/json' } });
  const bundle = await readApiJson(res, 'GRIB bundle endpoint');
  const models = Array.isArray(bundle.models)
    ? bundle.models.filter(payload => Array.isArray(payload?.hours) && payload.hours.length)
    : [];
  if(!models.length) throw new Error('No usable GRIB bundle data');

  comparisonData = {};
  comparisonSkippedGribs = groupedSkippedGribs(Array.isArray(bundle.skippedFiles) ? bundle.skippedFiles : []);
  comparisonTimelineBaseDate = dateVal || null;
  const timeWindow = gribBundleWindow(models);
  comparisonConfigs = models.map((payload, i) => {
    const cfg = gribCompareConfig(payload, i);
    comparisonData[cfg.id] = gribBundleComparison(payload, cfg, loadedAt, timeWindow);
    return cfg;
  });

  const status = document.getElementById('compareStatus');
  const skippedCount = comparisonSkippedGribs.length;
  const skipped = skippedCount ? ` · skipped ${skippedCount}` : '';
  status.textContent = `${models.length} GRIB model(s) loaded${skipped} · first ${COMPARE_GRIB_MAX_HOURS}h · ${formatCoord(lat, lon)} · ${fmtDate(dateVal)}`;
  setStatus('green', `GRIB bundle loaded: ${models.length} model(s)`);
  renderComparison();
}

async function fetchOpenMeteoComparison(lat, lon, dateVal, dateParam, loadedAt){
  comparisonSkippedGribs = [];
  comparisonTimelineBaseDate = dateVal || null;
  const openMeteoConfigs = OPENMETEO_COMPARE_MODELS;
  comparisonConfigs = openMeteoConfigs;
  const results = await Promise.allSettled(openMeteoConfigs.map(async cfg => {
    const url = cfg.base
      + `?latitude=${lat}&longitude=${lon}`
      + '&hourly=temperature_2m,wind_speed_10m,wind_direction_10m,wind_gusts_10m,weathercode,cape,precipitation'
      + '&timezone=Europe%2FRome&wind_speed_unit=kn'
      + cfg.param + dateParam;
    const res = await fetch(url);
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    if(data.error) throw new Error(data.reason || 'API error');
    return { cfg, data };
  }));

  comparisonData = {};
  await Promise.all(results.map(async (result, i) => {
    const cfg = openMeteoConfigs[i];
    if(result.status !== 'fulfilled'){
      comparisonData[cfg.id] = { cfg, error: result.reason?.message || 'No data' };
      return;
    }
    const h = result.value.data.hourly;
    const metadata = await openMeteoCompareMeta(cfg, result.value.data, loadedAt);
    comparisonData[cfg.id] = {
      cfg,
      hours: h.time.map(t => parseInt(t.split('T')[1], 10)),
      tws: h.wind_speed_10m,
      twd: h.wind_direction_10m,
      gust: h.wind_gusts_10m,
      temp: h.temperature_2m,
      wmo: h.weathercode,
      cape: h.cape,
      rain: h.precipitation,
      metadata,
    };
  }));
  const loaded = Object.values(comparisonData).filter(m => !m.error).length;
  const status = document.getElementById('compareStatus');
  status.textContent = `${loaded}/${openMeteoConfigs.length} Open-Meteo models loaded · ${formatCoord(lat, lon)} · ${fmtDate(dateVal)}`;
  setStatus(loaded ? 'green' : 'red', loaded ? 'Open-Meteo comparison loaded.' : 'No comparison models loaded.');
  renderComparison();
}

async function fetchModelComparison(){
  const lat = parseFloat(document.getElementById('latInput').value);
  const lon = parseFloat(document.getElementById('lonInput').value);
  if(isNaN(lat) || isNaN(lon)){
    setStatus('red', 'Set location before model comparison.');
    return;
  }
  const dateVal = document.getElementById('fDate').value || new Date().toISOString().split('T')[0];
  const dateParam = `&start_date=${dateVal}&end_date=${dateVal}`;
  const source = selectedComparisonSource();
  const status = document.getElementById('compareStatus');
  const sourceLabel = comparisonSourceLabel(source);
  status.textContent = source === 'openmeteo' ? 'Fetching Open-Meteo comparison...' : 'Extracting GRIB bundle comparison...';
  document.getElementById('compareGrid').innerHTML = `<div class="empty">Loading ${escapeHtml(sourceLabel)} data...</div>`;
  document.getElementById('compareHourRow').style.display = 'none';
  document.getElementById('compareChartWrap').style.display = 'none';
  document.getElementById('compareAgreement').style.display = 'none';
  const skippedEl = document.getElementById('compareSkipped');
  if(skippedEl){
    skippedEl.style.display = 'none';
    skippedEl.innerHTML = '';
  }

  const loadedAt = new Date().toISOString();
  try {
    if(source === 'openmeteo'){
      await fetchOpenMeteoComparison(lat, lon, dateVal, dateParam, loadedAt);
    } else {
      await fetchGribBundleComparison(lat, lon, loadedAt, dateVal);
    }
  } catch(e){
    comparisonData = {};
    comparisonConfigs = source === 'openmeteo' ? COMPARE_MODEL_CONFIGS.filter(cfg => cfg.source !== 'local-grib') : COMPARE_MODEL_CONFIGS;
    comparisonSkippedGribs = [];
    comparisonSelectedHour = null;
    comparisonTimelineBaseDate = null;
    const hint = source === 'grib' ? ' Select Open-Meteo as the comparison source to fetch remote model data.' : '';
    status.textContent = `${sourceLabel} comparison failed: ${e.message}`;
    document.getElementById('compareGrid').innerHTML = `<div class="err">${escapeHtml(sourceLabel)} comparison failed: ${escapeHtml(e.message)}.${escapeHtml(hint)}</div>`;
    setStatus('red', `${sourceLabel} comparison failed.`);
  }
}

function compareSlice(model, fromStr, toStr){
  if(!model || model.error || !model.hours) return null;
  const from = parseInt(fromStr.split(':')[0], 10);
  const to = parseInt(toStr.split(':')[0], 10);
  const idxs = model.hours.reduce((acc, h, i) => {
    if(h >= from && h < to) acc.push(i);
    return acc;
  }, []);
  if(!idxs.length) return null;
  const twd = windDirMean(model.twd, idxs);
  const rainVals = validVals(model.rain, idxs);
  return {
    twd,
    twdStr: degToDir(twd),
    twsAvg: avgValue(model.tws, idxs),
    twsMin: minValue(model.tws, idxs),
    twsMax: maxValue(model.tws, idxs),
    gust: maxValue(model.gust, idxs),
    sky: wmoSky(parseInt(modeValue(model.wmo, idxs), 10)),
    cape: maxValue(model.cape, idxs),
    rain: rainVals.length ? (model.metadata?.rainMode === 'rate' ? avgValue(model.rain, idxs) : rainVals.reduce((a, b) => a + b, 0)) : null,
    wave: avgValue(model.wave, idxs),
    waveDir: windDirMean(model.waveDir, idxs),
  };
}

function comparisonLoadedEntries(){
  return comparisonConfigs
    .map(cfg => ({ cfg, model: comparisonData[cfg.id] }))
    .filter(entry => entry.model && !entry.model.error && Array.isArray(entry.model.hours) && entry.model.hours.length);
}

function comparisonHours(entries = comparisonLoadedEntries()){
  const hours = new Set();
  entries.forEach(({ model }) => {
    model.hours.forEach(h => {
      const n = Number(h);
      if(!isNaN(n)) hours.add(n);
    });
  });
  return Array.from(hours).sort((a, b) => a - b);
}

function nearestComparisonHour(hour, hours = comparisonHours()){
  if(!hours.length) return null;
  if(hour == null || isNaN(hour)) return hours[0];
  return hours.reduce((best, h) => Math.abs(h - hour) < Math.abs(best - hour) ? h : best, hours[0]);
}

function comparisonHourLabel(hour){
  const n = Number(hour);
  if(isNaN(n)) return '--';
  const rounded = Math.round(n);
  if(comparisonTimelineBaseDate){
    const base = new Date(`${comparisonTimelineBaseDate}T00:00:00`);
    if(!isNaN(base)){
      base.setHours(base.getHours() + rounded);
      return `${COMPARE_DAY_LABELS[base.getDay()]} ${String(base.getHours()).padStart(2, '0')}`;
    }
  }
  if(rounded >= 24) return `D+${Math.floor(rounded / 24)} ${String(rounded % 24).padStart(2, '0')}`;
  return `${String(rounded).padStart(2, '0')}:00`;
}

function setComparisonSliderFill(slider){
  if(!slider) return;
  const min = Number(slider.min);
  const max = Number(slider.max);
  const value = Number(slider.value);
  const pct = max === min ? 100 : Math.max(0, Math.min(100, ((value - min) / (max - min)) * 100));
  slider.style.background = `linear-gradient(to right,var(--primary) ${pct}%,var(--border) ${pct}%)`;
}

function setComparisonHour(rawHour, redraw = true){
  const hours = comparisonHours();
  comparisonSelectedHour = nearestComparisonHour(Number(rawHour), hours);
  const label = document.getElementById('compareHourLabel');
  if(label) label.textContent = comparisonSelectedHour == null ? '--:--' : comparisonHourLabel(comparisonSelectedHour);
  const slider = document.getElementById('compareHourSlider');
  if(slider && comparisonSelectedHour != null){
    slider.value = comparisonSelectedHour;
    setComparisonSliderFill(slider);
  }
  if(redraw){
    renderComparisonCards();
    renderComparisonAgreement();
    renderComparisonCharts();
  }
}

function handleComparisonHourInput(input){
  const previewHour = nearestComparisonHour(Number(input.value));
  const label = document.getElementById('compareHourLabel');
  if(label) label.textContent = previewHour == null ? '--' : comparisonHourLabel(previewHour);
  setComparisonSliderFill(input);
}

function commitComparisonHour(rawHour){
  const scrollX = window.scrollX;
  const scrollY = window.scrollY;
  setComparisonHour(rawHour, true);
  requestAnimationFrame(() => window.scrollTo(scrollX, scrollY));
}

function handleComparisonHourChange(input){
  commitComparisonHour(input.value);
}

function renderComparisonHourControl(){
  const row = document.getElementById('compareHourRow');
  if(!row) return;
  const hours = comparisonHours();
  if(!hours.length){
    row.style.display = 'none';
    row.innerHTML = '';
    return;
  }
  comparisonSelectedHour = nearestComparisonHour(comparisonSelectedHour, hours);
  const minH = hours[0];
  const maxH = hours[hours.length - 1];
  row.innerHTML = `<div class="chr-wrap">
    <div class="chr-label-wrap">
      <span class="chr-label" id="compareHourLabel">${comparisonHourLabel(comparisonSelectedHour)}</span>
      <span class="chr-sublabel">Local time</span>
    </div>
    <input type="range" class="chr-slider" id="compareHourSlider" min="${minH}" max="${maxH}" step="1" value="${comparisonSelectedHour}" oninput="handleComparisonHourInput(this)" onchange="handleComparisonHourChange(this)">
  </div>`;
  row.style.display = 'flex';
  setComparisonSliderFill(document.getElementById('compareHourSlider'));
}

function compareHourData(model, hour = comparisonSelectedHour){
  if(!model || model.error || !Array.isArray(model.hours) || hour == null) return null;
  const idx = model.hours.findIndex(h => Number(h) === Number(hour));
  if(idx < 0) return null;
  return {
    tws: validNumber(model.tws?.[idx]),
    gust: validNumber(model.gust?.[idx]),
    twd: validNumber(model.twd?.[idx]),
    temp: validNumber(model.temp?.[idx]),
    wmo: validNumber(model.wmo?.[idx]),
    cape: validNumber(model.cape?.[idx]),
    rain: validNumber(model.rain?.[idx]),
    wave: validNumber(model.wave?.[idx]),
    waveDir: validNumber(model.waveDir?.[idx]),
  };
}

function validNumber(value){
  const n = Number(value);
  return value == null || isNaN(n) ? null : n;
}

function compareMetricCell(label, value, valueClass = '', cellClass = '', valueStyle = ''){
  const cellCls = ['compare-data-cell', cellClass].filter(Boolean).join(' ');
  const valCls = ['compare-data-val', valueClass].filter(Boolean).join(' ');
  return `<div class="${cellCls}">
    <div class="${valCls}"${valueStyle}>${escapeHtml(value)}</div>
    <div class="compare-data-label">${escapeHtml(label)}</div>
  </div>`;
}

function compareWaveText(d){
  if(d.wave == null && d.waveDir == null) return '—';
  const height = d.wave == null ? '—' : `${Number(d.wave).toFixed(1)} m`;
  const direction = d.waveDir == null ? '' : ` ${degToDir(d.waveDir)} ${Math.round(d.waveDir)}°`;
  return `${height}${direction}`;
}

function renderComparison(){
  const grid = document.getElementById('compareGrid');
  if(!grid) return;
  if(!Object.keys(comparisonData).length){
    grid.innerHTML = `<div class="empty">${escapeHtml(comparisonEmptyMessage())}</div>`;
    document.getElementById('compareHourRow').style.display = 'none';
    document.getElementById('compareChartWrap').style.display = 'none';
    document.getElementById('compareAgreement').style.display = 'none';
    renderSkippedGribs();
    return;
  }
  renderComparisonHourControl();
  renderComparisonCards();
  renderSkippedGribs();
  renderComparisonAgreement();
  renderComparisonCharts();
  setupComparisonChartResize();
}

function renderComparisonCards(){
  const grid = document.getElementById('compareGrid');
  if(!grid) return;
  grid.innerHTML = comparisonConfigs.map((cfg, index) => {
    const model = comparisonData[cfg.id];
    const modelStyle = ` style="--model-col:${compareModelColor(cfg, index)}"`;
    if(!model || model.error){
      return `<article class="compare-card"${modelStyle}>
        ${compareModelHeaderHtml(cfg, model)}
        <div class="compare-period-sub">No data: ${escapeHtml(model?.error || 'not loaded')}</div>
        ${model?.readiness ? `<div class="compare-period-sub">${escapeHtml(model.readiness)}</div>` : ''}
      </article>`;
    }
    const d = compareHourData(model);
    const cells = d ? [
      compareMetricCell('TWS', d.tws == null ? '—' : `${Math.round(d.tws)} kt`, 'wind-speed-val', '', windSpeedStyle(d.tws)),
      compareMetricCell('Gust', d.gust == null ? '—' : `${Math.round(d.gust)} kt`, 'wind-speed-val', '', windSpeedStyle(d.gust)),
      compareMetricCell('TWD', d.twd == null ? '—' : `${Math.round(d.twd)}°`),
      d.temp == null ? '' : compareMetricCell('Temp', `${Math.round(d.temp)}°C`),
      d.wmo == null ? '' : compareMetricCell('Weather', wmoSky(Math.round(d.wmo))),
      d.cape == null ? '' : compareMetricCell('CAPE', `${Math.round(d.cape)} J/kg`, capeClass(d.cape)),
      d.rain == null ? '' : compareMetricCell('Rain', fmtRain(d.rain, model.metadata?.rainMode), 'compare-val-rain', 'compare-cell-rain'),
      d.wave == null && d.waveDir == null ? '' : compareMetricCell('Sig Wave', compareWaveText(d), 'compare-val-wave', 'compare-cell-wave'),
    ].filter(Boolean).join('') : '';
    return `<article class="compare-card"${modelStyle}>
      ${compareModelHeaderHtml(cfg, model)}
      ${d ? `<div class="compare-data-grid">${cells}</div>` : '<div class="compare-period-sub">No data for selected hour.</div>'}
    </article>`;
  }).join('');
}

