function renderCompareLineChart(canvasId, key, unit, isDirection, entries = comparisonWindChartEntries()){
  const canvas = document.getElementById(canvasId);
  if(!canvas) return;
  const hours = comparisonHours(entries);
  const series = compareSeries(entries, hours, key);
  const values = series.flatMap(s => s.values).filter(v => v != null);
  if(!values.length){
    const ctx = canvas.getContext('2d');
    if(ctx) ctx.clearRect(0, 0, canvas.width, canvas.height);
    return;
  }

  let width = 0;
  let el = canvas.parentElement;
  while(el && !width){ width = el.offsetWidth; el = el.parentElement; }
  width = Math.max(320, (width || 820) - 48);
  const height = isDirection ? 220 : 280;
  const dpr = window.devicePixelRatio || 1;
  canvas.width = width * dpr;
  canvas.height = height * dpr;
  canvas.style.width = `${width}px`;
  canvas.style.height = `${height}px`;

  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, width, height);

  const styles = getComputedStyle(document.documentElement);
  const textCol = styles.getPropertyValue('--muted').trim() || '#777';
  const gridCol = styles.getPropertyValue('--border').trim() || '#ddd';
  const avgCol = styles.getPropertyValue('--text').trim() || '#111';
  const surfaceCol = styles.getPropertyValue('--surface').trim() || '#fff';
  const primaryCol = styles.getPropertyValue('--primary').trim() || '#2b5f91';
  const pad = { t:24, r:16, b:32, l:42 };
  const chartW = width - pad.l - pad.r;
  const chartH = height - pad.t - pad.b;
  const yMin = isDirection ? 0 : 0;
  const yMax = isDirection ? 360 : Math.max(20, Math.ceil((Math.max(...values) + 4) / 5) * 5);
  const xFor = i => pad.l + (i / (hours.length - 1 || 1)) * chartW;
  const yFor = v => pad.t + chartH - ((v - yMin) / (yMax - yMin || 1)) * chartH;

  ctx.font = '11px sans-serif';
  ctx.textAlign = 'right';
  if(isDirection){
    [0, 90, 180, 270, 360].forEach((deg, i) => {
      const y = yFor(deg);
      ctx.strokeStyle = gridCol;
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(pad.l + chartW, y); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = textCol;
      ctx.fillText(['N', 'E', 'S', 'W', 'N'][i], pad.l - 6, y + 4);
    });
  } else {
    for(let i = 0; i <= 4; i++){
      const v = yMin + (yMax - yMin) * i / 4;
      const y = yFor(v);
      ctx.strokeStyle = gridCol;
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(pad.l + chartW, y); ctx.stroke();
      ctx.fillStyle = textCol;
      ctx.fillText(`${Math.round(v)} ${unit}`, pad.l - 6, y + 4);
    }
  }

  ctx.textAlign = 'center';
  const labelStep = Math.max(1, Math.ceil(hours.length / 8));
  hours.forEach((hour, i) => {
    if(i % labelStep !== 0 && i !== hours.length - 1) return;
    ctx.fillStyle = textCol;
    ctx.fillText(comparisonHourLabel(hour), xFor(i), height - pad.b + 16);
  });

  if(!isDirection){
    const bandMin = hours.map((_, i) => {
      const vals = series.map(s => s.values[i]).filter(v => v != null);
      return vals.length ? Math.min(...vals) : null;
    });
    const bandMax = hours.map((_, i) => {
      const vals = series.map(s => s.values[i]).filter(v => v != null);
      return vals.length ? Math.max(...vals) : null;
    });
    ctx.beginPath();
    bandMax.forEach((v, i) => {
      if(v == null) return;
      const x = xFor(i);
      const y = yFor(v);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    for(let i = bandMin.length - 1; i >= 0; i--){
      if(bandMin[i] == null) continue;
      ctx.lineTo(xFor(i), yFor(bandMin[i]));
    }
    ctx.closePath();
    ctx.fillStyle = primaryCol;
    ctx.globalAlpha = 0.12;
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  series.forEach(s => {
    drawCompareSeries(ctx, s.values, hours, xFor, yFor, s.color, isDirection, 1.7, 0.72);
  });

  const avgSeries = hours.map((_, i) => {
    const vals = series.map(s => s.values[i]).filter(v => v != null);
    if(!vals.length) return null;
    return isDirection ? windDirMean(vals) : vals.reduce((a, b) => a + b, 0) / vals.length;
  });
  drawCompareSeries(ctx, avgSeries, hours, xFor, yFor, avgCol, isDirection, 3, 1);
  drawCompareHourMarker(ctx, hours, avgSeries, xFor, yFor, pad, chartH, height, unit, isDirection, avgCol, surfaceCol);
  attachCompareChartScrub(canvas, hours);
}

function drawCompareSeries(ctx, values, hours, xFor, yFor, color, isDirection, lineWidth, alpha){
  ctx.beginPath();
  ctx.strokeStyle = color;
  ctx.lineWidth = lineWidth;
  ctx.lineJoin = 'round';
  ctx.globalAlpha = alpha;
  let started = false;
  let prev = null;
  values.forEach((value, i) => {
    if(value == null){ started = false; prev = null; return; }
    const jump = isDirection && prev != null && Math.abs(value - prev) > 180;
    const x = xFor(i);
    const y = yFor(value);
    if(!started || jump){ ctx.moveTo(x, y); started = true; }
    else ctx.lineTo(x, y);
    prev = value;
  });
  ctx.stroke();
  ctx.globalAlpha = 1;
}

function drawCompareHourMarker(ctx, hours, avgSeries, xFor, yFor, pad, chartH, height, unit, isDirection, avgCol, surfaceCol){
  const idx = hours.findIndex(h => Number(h) === Number(comparisonSelectedHour));
  if(idx < 0) return;
  const x = xFor(idx);
  ctx.strokeStyle = avgCol;
  ctx.globalAlpha = 0.22;
  ctx.lineWidth = 1.5;
  ctx.setLineDash([3, 3]);
  ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, pad.t + chartH); ctx.stroke();
  ctx.setLineDash([]);
  ctx.globalAlpha = 1;

  const avg = avgSeries[idx];
  if(avg == null) return;
  const y = yFor(avg);
  ctx.fillStyle = avgCol;
  ctx.beginPath(); ctx.arc(x, y, 5, 0, Math.PI * 2); ctx.fill();
  ctx.strokeStyle = surfaceCol;
  ctx.lineWidth = 2;
  ctx.stroke();

  const label = isDirection ? `avg ${degToDir(avg)}` : `avg ${Math.round(avg)} ${unit}`;
  ctx.font = 'bold 11px sans-serif';
  const textW = ctx.measureText(label).width;
  const w = textW + 12;
  const h = 20;
  const lx = Math.max(pad.l + w / 2, Math.min(x, xFor(hours.length - 1) - w / 2));
  const ly = pad.t + 4;
  ctx.fillStyle = surfaceCol;
  ctx.strokeStyle = avgCol;
  ctx.lineWidth = 1.5;
  roundRect(ctx, lx - w / 2, ly, w, h, 4);
  ctx.fill();
  ctx.stroke();
  ctx.fillStyle = avgCol;
  ctx.textAlign = 'center';
  ctx.fillText(label, lx, ly + 14);
}

function roundRect(ctx, x, y, w, h, r){
  if(ctx.roundRect){
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
    return;
  }
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.arcTo(x + w, y, x + w, y + h, r);
  ctx.arcTo(x + w, y + h, x, y + h, r);
  ctx.arcTo(x, y + h, x, y, r);
  ctx.arcTo(x, y, x + w, y, r);
  ctx.closePath();
}

function attachCompareChartScrub(canvas, hours){
  let pendingHour = null;
  const hourFromEvent = e => {
    const rect = canvas.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const frac = Math.max(0, Math.min(1, (clientX - rect.left - 42) / Math.max(1, rect.width - 58)));
    const idx = Math.round(frac * (hours.length - 1));
    return hours[Math.max(0, Math.min(hours.length - 1, idx))];
  };
  const preview = e => {
    pendingHour = hourFromEvent(e);
    const label = document.getElementById('compareHourLabel');
    if(label) label.textContent = comparisonHourLabel(pendingHour);
    const slider = document.getElementById('compareHourSlider');
    if(slider){
      slider.value = pendingHour;
      setComparisonSliderFill(slider);
    }
  };
  const commit = () => {
    if(pendingHour != null) commitComparisonHour(pendingHour);
    pendingHour = null;
    canvas.onmousemove = null;
    canvas.ontouchmove = null;
  };
  canvas.style.cursor = 'ew-resize';
  canvas.onmousedown = e => { e.preventDefault(); preview(e); canvas.onmousemove = preview; document.onmouseup = commit; };
  canvas.ontouchstart = e => { e.preventDefault(); preview(e); canvas.ontouchmove = ev => { ev.preventDefault(); preview(ev); }; document.ontouchend = commit; };
}

