    <div class="agree-note">Bar length is agreement strength. TWS high agreement is &lt;2 kt spread; TWD high agreement is &lt;20° spread.</div>
  ` : '';
}

function agreementRow(label, values, unit, goodSpread, okSpread, circular){
  if(values.length < 2) return '';
  const spread = circular ? circularSpread(values) : Math.max(...values) - Math.min(...values);
  const avg = circular ? windDirMean(values) : values.reduce((a, b) => a + b, 0) / values.length;
  const cls = spread <= goodSpread ? 'agree-good' : spread <= okSpread ? 'agree-ok' : 'agree-poor';
  const max = okSpread * 2.5;
  const pct = Math.max(6, Math.min(100, 100 - (spread / max) * 100));
  const spreadText = circular ? `${Math.round(spread)}${unit}` : `${spread.toFixed(1)} ${unit}`;
  const avgText = circular ? `${degToDir(avg)} ${Math.round(avg)}°` : `${Math.round(avg)} ${unit}`;
  return `<div class="agree-row">
    <div class="agr-lbl">${escapeHtml(label)}</div>
    <div class="agree-bar-wrap"><div class="agree-bar ${cls}" style="width:${pct}%"></div></div>
    <div class="agr-spread">${escapeHtml(spreadText)}</div>
    <div class="agr-avg">avg ${escapeHtml(avgText)}</div>
  </div>`;
}

function circularSpread(degs){
  const mean = windDirMean(degs);
  if(mean == null) return 0;
  return degs.reduce((max, d) => Math.max(max, Math.abs(signedAngularDelta(mean, d))), 0) * 2;
}

const COMPARE_MODEL_COLORS = {
  gfs:'#3b82f6',
  ecmwf:'#10b981',
  aifs:'#8b5cf6',
  arpege:'#d79a2b',
  arome:'#f97316',
  icon:'#a855f7',
  ukmo:'#475569',
  metno:'#0284c7',
  harmonie:'#ca8a04',
  meteoswiss:'#dc2626',
  lamma:'#2f5f8f',
  wam:'#0f766e',
  squid:'#e11d48',
};
const COMPARE_MODEL_FALLBACK_COLORS = ['#3b82f6', '#10b981', '#f97316', '#a855f7', '#e11d48', '#64748b'];

function compareModelKey(cfg){
  const text = [cfg?.id, cfg?.label, cfg?.detail].filter(Boolean).join(' ').toLowerCase();
  if(text.includes('wam') || text.includes('mfwam') || text.includes('wave grib')) return 'wam';
  if(text.includes('aifs')) return 'aifs';
  if(text.includes('ecmwf') || text.includes('ifs')) return 'ecmwf';
  if(text.includes('gfs')) return 'gfs';
  if(text.includes('arpege')) return 'arpege';
  if(text.includes('arome')) return 'arome';
  if(text.includes('ukmo')) return 'ukmo';
  if(text.includes('metno') || text.includes('nordic')) return 'metno';
  if(text.includes('harmonie') || text.includes('knmi') || text.includes('dmi')) return 'harmonie';
  if(text.includes('meteoswiss') || text.includes('icon_ch')) return 'meteoswiss';
  if(text.includes('icon')) return 'icon';
  if(text.includes('lamma')) return 'lamma';
  if(text.includes('squid')) return 'squid';
  return '';
}

function compareModelColor(cfg, index = 0){
  const key = compareModelKey(cfg);
  return COMPARE_MODEL_COLORS[key] || COMPARE_MODEL_FALLBACK_COLORS[index % COMPARE_MODEL_FALLBACK_COLORS.length];
}

function modelHasAnyValue(model, key){
  return Array.isArray(model?.[key]) && model[key].some(value => value != null && !isNaN(value));
}

function comparisonWindChartEntries(){
