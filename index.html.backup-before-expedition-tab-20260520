function selectedPeriodIndices(){
  if(!forecastData?.hours?.length) return [];
  const active = PERIODS.filter(p => activePeriods.has(p.id));
  const idxs = [];
  active.forEach(p => {
    const from = parseInt(p.from.split(':')[0], 10);
    const to = parseInt(p.to.split(':')[0], 10);
    forecastData.hours.forEach((h, i) => {
      if(h >= from && h < to && !idxs.includes(i)) idxs.push(i);
    });
  });
  if(idxs.length) return idxs.sort((a, b) => a - b);
  return forecastData.hours.map((_, i) => i).slice(0, 24);
}

function signedAngularDelta(fromDeg, toDeg){
  if(fromDeg == null || toDeg == null) return null;
  return ((toDeg - fromDeg + 540) % 360) - 180;
}

function hourClock(h){
  if(h == null || isNaN(h)) return '—';
  return `${String(Math.round(h)).padStart(2, '0')}:00`;
}

function hourClockAtIndex(i){
  return hourClock(forecastData?.hours?.[i]);
}

function hourRangeAtIndices(i0, i1){
  const a = hourClockAtIndex(i0);
  const b = hourClockAtIndex(i1);
  return a === b ? `~${a}` : `${a}–${b}`;
}

function dirShiftPhrase(delta){
  if(delta == null || Math.abs(delta) < 8) return null;
  return delta < 0 ? 'backing left' : 'veering right';
}

function detectBigShifts(idxs, key, threshold, maxLag = 3, angular = false){
  const arr = forecastData?.[key];
  if(!arr || idxs.length < 2) return [];
  const found = [];
  let a = 0;
  while(a < idxs.length - 1){
    const i0 = idxs[a];
    const v0 = arr[i0];
    if(v0 == null || isNaN(v0)){ a++; continue; }
    let best = null;
    let bestB = a;
    for(let b = a + 1; b < idxs.length && b - a <= maxLag; b++){
      const i1 = idxs[b];
      const v1 = arr[i1];
      if(v1 == null || isNaN(v1)) continue;
      const delta = angular ? signedAngularDelta(v0, v1) : v1 - v0;
      if(delta == null || Math.abs(delta) < threshold) continue;
      if(!best || Math.abs(delta) > Math.abs(best.delta)){
        best = { fromIdx: i0, toIdx: i1, fromVal: v0, toVal: v1, delta };
        bestB = b;
      }
    }
    if(best){
      found.push(best);
      a = bestB + 1;
    } else a++;
  }
  return found;
}

function formatTwdShiftLine(shift){
  const when = hourRangeAtIndices(shift.fromIdx, shift.toIdx);
  const phrase = dirShiftPhrase(shift.delta) || 'shifts';
  const mag = Math.round(Math.abs(shift.delta));
  const arrow = `${degToDir(shift.fromVal)} ${Math.round(shift.fromVal)}° → ${degToDir(shift.toVal)} ${Math.round(shift.toVal)}°`;
  const htmlArrow = `<strong>${escapeHtml(degToDir(shift.fromVal))}</strong> ${Math.round(shift.fromVal)}° → <strong>${escapeHtml(degToDir(shift.toVal))}</strong> ${Math.round(shift.toVal)}°`;
  return {
    type: 'wind',
    html: `TWD ${htmlArrow} · ${escapeHtml(phrase)} · <strong>${escapeHtml(when)}</strong> (${mag}°)`,
    text: `TWD ${arrow} · ${phrase} · ${when} (${mag}°)`,
  };
}

function formatTwsShiftLine(shift){
  const when = hourRangeAtIndices(shift.fromIdx, shift.toIdx);
  const verb = shift.delta > 0 ? 'builds' : 'eases';
  const body = `${verb} ${Math.round(shift.fromVal)} → ${Math.round(shift.toVal)} kt`;
  return {
    type: 'wind',
    html: `TWS ${escapeHtml(body)} · <strong>${escapeHtml(when)}</strong>`,
    text: `TWS ${body} · ${when}`,
  };
}

function renderDailyDetailHtml(lines){
  if(!lines?.length) return '';
