function sliceHours(fromStr, toStr){
  if(!forecastData) return null;
  const fh = parseInt(fromStr.split(':')[0], 10);
  const th = parseInt(toStr.split(':')[0], 10);
  const idxs = forecastData.hours.reduce((acc, h, i) => {
    if(h >= fh && h < th) acc.push(i);
    return acc;
  }, []);
  if(!idxs.length) return null;

  function vals(arr){
    return idxs.map(i => arr?.[i]).filter(x => x != null && !isNaN(x));
  }

  const twdDeg = windDirMean(forecastData.twd, idxs);
  const gwdDeg = windDirMean(forecastData.gwd, idxs);
  const waveH = avgValue(forecastData.wave, idxs);
  const waveDir = windDirMean(forecastData.waveDir, idxs);
  const rainVals = validVals(forecastData.rain, idxs);
  const capeMax = maxValue(forecastData.cape, idxs);
  const uvMax = maxValue(forecastData.uv, idxs);

  return {
    tempMin: minValue(forecastData.temp, idxs),
    tempMax: maxValue(forecastData.temp, idxs),
    twsMin: minValue(forecastData.tws, idxs),
    twsMax: maxValue(forecastData.tws, idxs),
    gust: maxValue(forecastData.gust, idxs),
    twdDeg,
    twdStr: degToDir(twdDeg),
    gwdDeg,
    gwdStr: degToDir(gwdDeg),
    sky: wmoSky(parseInt(modeValue(forecastData.wmo, idxs), 10)),
    capeMax,
    uvMax,
    rain: rainVals.length ? (forecastMeta?.rainMode === 'rate' ? avgValue(forecastData.rain, idxs) : rainVals.reduce((a, b) => a + b, 0)) : null,
    waveH,
    waveDir,
    waveDirStr: degToDir(waveDir),
    sea: waveDesc(waveH),
  };
}

async function fetchForecast(){
  const lat = parseFloat(document.getElementById('latInput').value);
  const lon = parseFloat(document.getElementById('lonInput').value);
  if(isNaN(lat) || isNaN(lon)){
    setStatus('red', 'Invalid coordinates');
    return;
  }

  const btn = document.getElementById('fetchBtn');
  btn.disabled = true;
  setStatus('yellow', 'Contacting Open-Meteo…');

  try {
  const selDate = document.getElementById('fDate').value;
  const today = new Date().toISOString().split('T')[0];
  const targetDate = selDate || today;
  const dateParam = `&start_date=${targetDate}&end_date=${targetDate}`;

  const modelId = resolveOpenMeteoModelId(document.getElementById('briefingModel').value);
  const modelCfg = getOpenMeteoModel(modelId);
  if(!modelCfg) throw new Error('Unknown Open-Meteo model selection.');
  assertOpenMeteoDateLimit(modelCfg, targetDate);

  const weatherURL = modelCfg.base
    + `?latitude=${lat}&longitude=${lon}`
    + '&hourly=temperature_2m,wind_speed_10m,wind_direction_10m,wind_direction_850hPa,wind_gusts_10m,weathercode,cape,uv_index'
    + '&timezone=Europe%2FRome&wind_speed_unit=kn'
    + modelCfg.param + dateParam;

  const marineURL = 'https://marine-api.open-meteo.com/v1/marine'
    + `?latitude=${lat}&longitude=${lon}`
    + '&hourly=wave_height'
    + '&timezone=Europe%2FRome' + dateParam;

    const [wRes, mRes] = await Promise.all([fetch(weatherURL), fetch(marineURL)]);
    if(!wRes.ok) throw new Error(`Weather API ${wRes.status}`);

    const wData = await wRes.json();
    if(wData.error) throw new Error(wData.reason || 'Weather API error');

    let wave = null;
    if(mRes.ok){
      const mData = await mRes.json();
      wave = mData.hourly?.wave_height || null;
    }

    const twsSeries = wData.hourly?.wind_speed_10m;
    if(modelCfg.domainMsg && (!twsSeries || !twsSeries.some(v => v != null))){
      throw new Error(modelCfg.domainMsg + ' Try ECMWF IFS HRES or ICON-EU.');
    }

    gribSourceLabel = null;
    forecastData = {
      hours: wData.hourly.time.map(t => parseInt(t.split('T')[1], 10)),
      temp: wData.hourly.temperature_2m,
      tws: wData.hourly.wind_speed_10m,
      twd: wData.hourly.wind_direction_10m,
      gwd: wData.hourly.wind_direction_850hPa,
      gust: wData.hourly.wind_gusts_10m,
      wmo: wData.hourly.weathercode,
      cape: wData.hourly.cape,
      uv: wData.hourly.uv_index,
      wave,
    };

    const stamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    const label = openMeteoModelLabel(modelId);
    const omLabel = `Open-Meteo ${label}`;
    forecastMeta = {
      source: 'Open-Meteo',
      modelLabel: label,
      model: modelId,
      date: targetDate,
      loadedAt: new Date().toISOString(),
      fieldSources: {
        wind: omLabel, gust: omLabel, twd: omLabel, gwd: omLabel,
        temp: omLabel, sky: omLabel, cape: omLabel, rain: omLabel, uv: omLabel, wave: omLabel,
      },
    };
    setStatus('green', `${fmtDate(targetDate)} · ${label} · ${stamp}`);
    document.getElementById('lastUpdated').textContent = `Fetched ${stamp} UTC local display`;
    updateSupplementButtonVisibility();
    renderBrief();
  } catch(e){
    setStatus('red', 'Fetch error: ' + e.message);
    document.getElementById('forecastDoc').innerHTML =
      `<div class="err">Could not fetch data: ${e.message}</div>`;
  } finally {
    btn.disabled = false;
  }
}

function applySquidPayload(payload){
  if(!payload || !payload.hours || !payload.hours.length){
    throw new Error('Invalid squid_forecast.json');
  }
  const meta = payload.meta || {};
  forecastData = {
    hours: payload.hours,
    tws: payload.tws,
    twd: payload.twd,
    gwd: payload.gwd || payload.hours.map(() => null),
    gust: payload.gust,
    temp: payload.temp || payload.hours.map(() => null),
    wmo: payload.wmo || payload.hours.map(() => null),
    cape: payload.cape || payload.hours.map(() => null),
    rain: payload.rain || payload.hours.map(() => null),
    uv: payload.uv || payload.hours.map(() => null),
    wave: payload.wave || payload.hours.map(() => null),
    waveDir: payload.waveDir || payload.hours.map(() => null),
  };
  gribSourceLabel = meta.modelLabel || 'Squid GRIB';
  const gribFieldLabel = gribSourceLabel;
  forecastMeta = {
    ...meta,
    source: 'Squid GRIB',
    loadedAt: new Date().toISOString(),
    fieldSources: {
      wind: gribFieldLabel,
      gust: gribFieldLabel,
      twd: gribFieldLabel,
      gwd: gribFieldLabel,
      temp: seriesHasValues(forecastData.temp) ? gribFieldLabel : '',
      sky: seriesHasValues(forecastData.wmo) ? gribFieldLabel : '',
      cape: seriesHasValues(forecastData.cape) ? gribFieldLabel : '',
      rain: seriesHasValues(forecastData.rain) ? gribFieldLabel : '',
      uv: seriesHasValues(forecastData.uv) ? gribFieldLabel : '',
      wave: seriesHasValues(forecastData.wave) ? gribFieldLabel : '',
    },
  };
  const stamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
  const file = meta.file || 'loaded';
  const point = formatCoord(meta.lat, meta.lon);
  const grid = formatCoord(meta.gridLat, meta.gridLon);
  const run = formatRunTime(meta);
  const gridText = grid ? `grid ${grid}${meta.gridDistanceKm != null ? ` (${meta.gridDistanceKm} km)` : ''}` : '';
  const detail = [
    `${gribSourceLabel}: ${file}`,
    run ? `run ${run}` : '',
    `${payload.hours.length} hours`,
    point ? `pin ${point}` : '',
    gridText,
    meta.skippedFiles?.length ? `skipped ${meta.skippedFiles.length} newer out-of-area file(s)` : '',
  ].filter(Boolean).join(' | ');
  setSquidHint(detail);
  setStatus('green', `${gribSourceLabel} · ${file} · ${stamp}`);
  document.getElementById('lastUpdated').textContent = `GRIB loaded ${stamp}`;
  updateSupplementButtonVisibility();
  renderBrief();
}

async function refreshSquidGribHint(){
  const el = document.getElementById('squidGribHint');
  const sel = document.getElementById('squidGribSelect');
  if(!el) return;
  if(location.protocol === 'file:'){
    el.innerHTML = 'Double-click <strong>Start Weather Brief.command</strong>, then use the button below.';
    return;
  }
  try {
    const res = await fetch('/api/gribs');
    const h = await res.json();
    if(!h.dependencyOk){
      el.textContent = 'GRIB tools missing. Run: python3 -m pip install eccodes cfgrib';
      return;
    }
    if(sel){
      const current = sel.value;
      sel.innerHTML = '<option value="">Best usable for pin (auto)</option>';
      (h.gribs || []).forEach(grib => {
        const opt = document.createElement('option');
        opt.value = grib.name;
        opt.textContent = describeGrib(grib);
        sel.appendChild(opt);
      });
      if([...sel.options].some(opt => opt.value === current)) sel.value = current;
    }
    if(h.gribs?.length){
      el.textContent = `GRIB files available: ${h.gribs.length}. Auto uses newest file that covers the pin.`;
    } else {
      el.textContent = 'No GRIB in Squid Gribs/ yet - download in Squid X first.';
    }
  } catch {
    el.textContent = 'Start via Start Weather Brief.command, then load GRIB.';
