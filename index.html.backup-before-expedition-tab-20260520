}

function nudgePosition(bearingDeg, nm){
  const lat = parseFloat(document.getElementById('latInput').value);
  const lon = parseFloat(document.getElementById('lonInput').value);
  if(isNaN(lat) || isNaN(lon)) return;
  const br = bearingDeg * Math.PI / 180;
  const dLat = (nm / 60) * Math.cos(br);
  const dLon = (nm / 60) * Math.sin(br) / Math.cos(lat * Math.PI / 180);
  setPosition(lat + dLat, lon + dLon, { fromMap: true });
}

async function searchPlace(){
  const q = document.getElementById('placeSearch').value.trim();
  const resultsEl = document.getElementById('searchResults');
  if(!q){ resultsEl.style.display = 'none'; return; }
  resultsEl.style.display = 'block';
  resultsEl.innerHTML = '<div class="search-result"><span class="sr-sub">Searching…</span></div>';
  const urls = [
    `https://photon.komoot.io/api/?q=${encodeURIComponent(q)}&limit=6&lang=en`,
    `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=6`
  ];
  for(const url of urls){
    try {
      const res = await fetch(url, { headers: { Accept: 'application/json' } });
      if(!res.ok) continue;
      const raw = await res.json();
      let items = [];
      if(raw.features){
        items = raw.features.map(f => ({
          lat: f.geometry.coordinates[1],
          lon: f.geometry.coordinates[0],
          name: [f.properties.name, f.properties.city || f.properties.state, f.properties.country].filter(Boolean).join(', '),
          sub: [f.properties.type, f.properties.country].filter(Boolean).join(' · ')
        }));
      } else if(Array.isArray(raw)){
        items = raw.map(r => ({
          lat: parseFloat(r.lat),
          lon: parseFloat(r.lon),
          name: r.display_name.split(',').slice(0, 2).join(', '),
          sub: r.display_name.split(',').slice(2, 4).join(', ')
        }));
      }
      if(!items.length){
        resultsEl.innerHTML = '<div class="search-result"><span class="sr-sub">No results</span></div>';
        return;
      }
      resultsEl.innerHTML = items.map((r, i) =>
        `<button type="button" class="search-result" data-i="${i}">
          <div class="sr-name">${escapeHtml(r.name)}</div>
          <div class="sr-sub">${escapeHtml(r.sub || '')}</div>
        </button>`
      ).join('');
      resultsEl.querySelectorAll('.search-result').forEach((btn, i) => {
        btn.onclick = () => selectSearchResult(items[i].lat, items[i].lon, items[i].name);
      });
      return;
    } catch(e) { continue; }
  }
  resultsEl.innerHTML = '<div class="search-result"><span class="sr-sub">Search failed</span></div>';
}

