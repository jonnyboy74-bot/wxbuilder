    </div>
    <div class="fg">
      <label for="raceDay">Race day</label>
      <input id="raceDay" class="fc" type="text" value="" placeholder="e.g. Day 1">
    </div>
    <div class="manage-row">
      <button type="button" id="saveEventBtn" class="btn btn-ghost" onclick="saveCustomEvent()">Save event</button>
      <button type="button" class="btn btn-ghost" onclick="toggleEventManage()">Manage events</button>
    </div>
    <div id="eventManageList" class="manage-list" hidden></div>
  </section>

  <section>
    <div class="sec-label">Vessel</div>
    <div class="fg">
      <label for="vesselPreset">Boat</label>
      <select id="vesselPreset" class="fc" onchange="onVesselPresetChange()"></select>
    </div>
    <div class="fg">
      <label for="vesselName">Boat name</label>
      <input id="vesselName" class="fc" type="text" value="" placeholder="Boat name">
    </div>
    <div class="manage-row">
      <button type="button" id="saveVesselBtn" class="btn btn-ghost" onclick="saveCustomVessel()">Save boat</button>
      <button type="button" class="btn btn-ghost" onclick="toggleVesselManage()">Manage boats</button>
    </div>
    <div id="vesselManageList" class="manage-list" hidden></div>
  </section>

  <section>
    <div class="sec-label">Location</div>
    <div class="fg map-wrap">
      <label for="placeSearch">Search · click map to place pin</label>
      <input id="placeSearch" class="fc" type="search" placeholder="e.g. Sorrento, Gulf of Naples"
        autocomplete="off" onkeydown="if(event.key==='Enter'){event.preventDefault();searchPlace();}">
      <div id="searchResults" class="search-results"></div>
    </div>
    <div id="venueMap"></div>
    <p class="map-hint">Click open water or drag the pin. Coordinates show below the map.</p>
    <div class="coord-readout" id="coordReadout">40.626°N · 14.376°E</div>
    <div class="nudge-row">
      <span style="font-size:10px;color:var(--muted);align-self:center;margin-right:var(--s1)">Nudge</span>
      <button type="button" class="nudge-btn" onclick="nudgePosition(0,1)">1 nm N</button>
      <button type="button" class="nudge-btn" onclick="nudgePosition(90,1)">1 nm E</button>
      <button type="button" class="nudge-btn" onclick="nudgePosition(180,1)">1 nm S</button>
      <button type="button" class="nudge-btn" onclick="nudgePosition(270,1)">1 nm W</button>
      <button type="button" class="nudge-btn" onclick="nudgePosition(180,3)">3 nm S</button>
      <button type="button" class="nudge-btn" onclick="nudgePosition(180,5)">5 nm S</button>
    </div>
    <div class="fg" style="margin-top:var(--s3)">
      <label for="venuePreset">Location</label>
      <select id="venuePreset" class="fc" onchange="onVenuePresetChange()"></select>
    </div>
    <div class="fg">
      <label for="venueInput">Location name</label>
