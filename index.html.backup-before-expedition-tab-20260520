<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Layla — Navigation Brief | 2026 IMA Maxi Europeans</title>
<link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
<style>
:root{
  --bg:#fff;--surface:#fff;--border:#d7dce2;--motion:#e6e9ed;
  --text:#28251d;--muted:#7a7974;--inv:#fff;--err:#b64a4a;--gold:#d79a2b;--blue:#4f7fb2;--green:#10b981;
  --primary:#2f5f8f;--primary-h:#243f63;
  --r-md:.5rem;--r-lg:.75rem;--r-xl:1rem;
  --s1:.25rem;--s2:.5rem;--s3:.75rem;--s4:1rem;--s5:1.25rem;--s6:1.5rem;--s8:2rem;
  --xs:.8125rem;--sm:.9375rem;--base:1rem;--lg:1.35rem;
  --font:'Satoshi','Helvetica Neue',sans-serif;
  --sidebar-width:440px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{-webkit-font-smoothing:antialiased}
body{
  min-height:100dvh;font-family:var(--font);font-size:var(--sm);color:var(--text);background:var(--bg);
  display:grid;grid-template-columns:1fr;grid-template-rows:auto 1fr;height:100dvh;overflow:hidden;
}
body.sidebar-collapsed{--sidebar-width:0px}
.app-body{
  display:grid;grid-template-columns:var(--sidebar-width) 1fr;min-height:0;overflow:hidden;
}
.sidebar-panel{
  display:flex;min-width:0;max-width:100%;overflow:hidden;
  border-right:1px solid var(--motion);background:var(--surface);
}
body.sidebar-collapsed .sidebar-panel{border-right:none}
body.sidebar-collapsed .sidebar-resizer{display:none}
body.sidebar-collapsed aside{opacity:0;pointer-events:none;padding:0}
.sidebar-resizer{
  width:6px;flex-shrink:0;cursor:col-resize;background:var(--motion);
  transition:background .15s;
}
.sidebar-resizer:hover,.sidebar-resizer.dragging{background:var(--primary)}
.icon-btn{
  width:34px;height:34px;border-radius:var(--r-md);display:inline-flex;align-items:center;
  justify-content:center;color:var(--muted);border:1px solid var(--border);
}
.icon-btn:hover{background:var(--motion);color:var(--text)}
input,select,textarea,button{font:inherit;color:inherit}
button{cursor:pointer;background:none;border:none}

header{
  grid-column:1/-1;background:var(--surface);border-bottom:1px solid var(--motion);
  padding:var(--s3) var(--s6);display:flex;align-items:center;justify-content:space-between;gap:var(--s4);
}
.logo-name{font-size:var(--base);font-weight:700;letter-spacing:-.01em}
.logo-sub{font-size:var(--xs);color:var(--muted)}
.hdr-actions{display:flex;align-items:center;gap:var(--s2)}
.btn{
  display:inline-flex;align-items:center;gap:var(--s2);padding:var(--s2) var(--s4);
  border-radius:var(--r-md);font-size:var(--sm);font-weight:500;
}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-h)}
.btn-primary:disabled{opacity:.45;cursor:not-allowed}
.btn-squid{background:#2f5f8f;color:#fff;width:100%}
.btn-squid:hover{background:var(--primary-h)}
.btn-squid:disabled{opacity:.45;cursor:not-allowed}
.btn-ghost{color:var(--muted);border:1px solid var(--border)}
.btn-ghost:hover{background:#dedad4;color:var(--text)}

aside{
  flex:1;min-width:0;overflow-y:auto;padding:var(--s5);display:flex;flex-direction:column;gap:var(--s5);
}
aside::-webkit-scrollbar{width:4px}
aside::-webkit-scrollbar-thumb{background:var(--motion);border-radius:4px}
.app-body > main{min-width:0;min-height:0;overflow:hidden;display:flex;flex-direction:column}
.sec-label{
  font-size:var(--xs);font-weight:600;color:var(--muted);text-transform:uppercase;
  letter-spacing:.07em;margin-bottom:var(--s2);
}
.fg{display:flex;flex-direction:column;gap:var(--s1);margin-bottom:var(--s3)}
.fg label{font-size:var(--xs);font-weight:500;color:var(--muted)}
.fc{
  padding:var(--s2) var(--s3);border:1px solid var(--border);border-radius:var(--r-md);
  background:var(--bg);width:100%;
}
.fc:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(47,95,143,.16)}
.team-copy-box{
  min-height:150px;resize:vertical;font-size:11px;line-height:1.35;
  white-space:pre-wrap;font-family:var(--font);
}
.team-brief-visual{display:flex;flex-direction:column;gap:var(--s3);margin-top:var(--s3)}
.team-brief-visual .f-header{padding:var(--s3);border-radius:var(--r-lg)}
.team-brief-visual .f-venue{font-size:var(--base)}
.team-period-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--s3)}
.team-brief-visual .pcard{padding:var(--s3);border-radius:var(--r-lg);box-shadow:0 3px 10px rgba(40,37,29,.12)}
.team-brief-visual .pt-row{margin-bottom:var(--s2)}
.team-brief-visual .frow{font-size:var(--xs)}
.team-visual-hint{font-size:10px;color:var(--muted);line-height:1.35;margin-top:var(--s2)}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:var(--s2)}
.status-row{display:flex;align-items:center;gap:var(--s2);font-size:var(--xs);color:var(--muted)}
.dot{width:8px;height:8px;border-radius:50%;background:var(--border)}
.dot.green{background:#4f7fb2}.dot.yellow{background:#d79a2b}.dot.red{background:#b64a4a}

.period-list{display:flex;flex-direction:column;gap:var(--s2)}
.period-row{
  display:flex;align-items:center;gap:var(--s3);padding:var(--s3);
  border:1px solid var(--border);border-radius:var(--r-md);background:var(--bg);cursor:pointer;
}
.period-row.active{border-color:var(--primary);background:rgba(47,95,143,.08)}
.period-check{
  width:18px;height:18px;border-radius:4px;border:1.5px solid var(--border);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.period-row.active .period-check{background:var(--primary);border-color:var(--primary)}
.pr-name{font-weight:600;font-size:var(--sm);flex:1}
.pr-time{font-size:var(--xs);color:var(--muted)}

.map-wrap{position:relative;margin-bottom:var(--s3)}
#venueMap{height:220px;border-radius:var(--r-lg);border:1px solid var(--border);background:var(--bg);z-index:0}
#venueMap .leaflet-container{border-radius:var(--r-lg);font-family:var(--font)}
.map-hint{font-size:10px;color:var(--muted);line-height:1.4;margin-top:var(--s2)}
.search-results{
  position:absolute;left:0;right:0;top:100%;z-index:1000;margin-top:2px;
  background:var(--bg);border:1px solid var(--border);border-radius:var(--r-md);
  box-shadow:0 8px 24px rgba(40,37,29,.12);max-height:160px;overflow-y:auto;display:none;
}
.search-result{
  display:block;width:100%;text-align:left;padding:var(--s2) var(--s3);
  border-bottom:1px solid var(--motion);font-size:var(--xs);
}
.search-result:hover{background:var(--surface)}
.search-result:last-child{border-bottom:none}
.sr-name{font-weight:600;color:var(--text)}
.sr-sub{color:var(--muted);font-size:10px;margin-top:1px}
.nudge-row{display:flex;flex-wrap:wrap;gap:var(--s1);margin-top:var(--s2)}
.nudge-btn{
  padding:3px 8px;font-size:10px;font-weight:600;border:1px solid var(--border);
  border-radius:var(--r-md);background:var(--bg);color:var(--muted);
}
.nudge-btn:hover{border-color:var(--primary);color:var(--primary)}
.coord-readout{font-size:10px;color:var(--muted);font-variant-numeric:tabular-nums;margin-top:var(--s1)}
.manage-row{display:flex;gap:var(--s2);margin-top:var(--s1)}
.manage-row .btn{flex:1;font-size:var(--xs);justify-content:center}
.manage-list{
  margin-top:var(--s2);border:1px solid var(--border);border-radius:var(--r-md);
  background:var(--bg);max-height:160px;overflow-y:auto;
}
.manage-item{
  display:flex;align-items:center;gap:var(--s2);padding:var(--s2) var(--s3);
  border-bottom:1px solid var(--motion);font-size:var(--xs);
}
.manage-item:last-child{border-bottom:none}
.manage-item-main{flex:1;min-width:0}
.manage-item-name{font-weight:600;color:var(--text)}
.manage-item-sub{color:var(--muted);font-size:10px;margin-top:1px}
.manage-item-actions{display:flex;gap:var(--s1);flex-shrink:0}
.manage-item-actions .btn{padding:2px 8px;font-size:10px}
.manage-empty{padding:var(--s3);color:var(--muted);font-size:var(--xs);text-align:center}
.manage-clear{
  padding:var(--s2) var(--s3);border-top:1px solid var(--motion);
  font-size:var(--xs);
}
.manage-clear .btn{width:100%;justify-content:center;font-size:var(--xs)}

.toolbar{
  flex-shrink:0;padding:var(--s4) var(--s6);border-bottom:1px solid var(--motion);background:var(--surface);
  display:flex;align-items:center;justify-content:space-between;gap:var(--s4);
}
.toolbar h2{font-size:var(--base);font-weight:600}
.tab-bar{display:flex;align-items:center;gap:var(--s2);flex-wrap:wrap}
.tab-btn{
  padding:var(--s2) var(--s4);border:1px solid var(--border);border-radius:var(--r-md);
  color:var(--muted);font-size:var(--xs);font-weight:600;background:var(--surface);
}
.tab-btn.active{background:var(--primary);border-color:var(--primary);color:var(--inv)}
.preview-area{
  flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;
  padding:var(--s8) var(--s6);display:flex;justify-content:center;align-items:flex-start;
}
.preview-area::-webkit-scrollbar{width:8px}
.preview-area::-webkit-scrollbar-thumb{background:var(--motion);border-radius:4px}
.preview-area::-webkit-scrollbar-thumb:hover{background:var(--border)}
.forecast-doc{width:100%;max-width:760px;display:flex;flex-direction:column;gap:var(--s4);flex-shrink:0}
.compare-panel{width:100%;max-width:980px;display:none;flex-direction:column;gap:var(--s4);flex-shrink:0}
.compare-head{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r-xl);
  padding:var(--s4) var(--s5);display:flex;align-items:center;justify-content:space-between;gap:var(--s4);
}
.compare-title{font-size:var(--lg);font-weight:800;letter-spacing:-.02em}
.compare-sub{font-size:var(--xs);color:var(--muted);margin-top:var(--s1)}
.compare-actions{display:flex;align-items:flex-end;gap:var(--s3);flex-wrap:wrap;justify-content:flex-end}
.compare-source{min-width:calc(var(--s12) * 3);margin-bottom:0}
.compare-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--s4)}
.compare-hour-row{display:none}
.chr-wrap{display:flex;align-items:center;gap:var(--s3);width:100%}
.chr-label-wrap{display:flex;flex-direction:column;align-items:center;flex-shrink:0}
.chr-label{
  font-size:var(--sm);font-weight:800;background:var(--primary);color:var(--inv);
  padding:var(--s1) var(--s3);border-radius:var(--r-md);white-space:nowrap;
}
.chr-sublabel{font-size:var(--xs);color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:var(--s1);white-space:nowrap}
.chr-slider{
  flex:1;appearance:none;height:var(--s1);border-radius:var(--r-full);
  background:linear-gradient(to right,var(--primary) 0%,var(--border) 0%);outline:none;cursor:pointer;
}
.chr-slider::-webkit-slider-thumb{
  appearance:none;width:var(--s5);height:var(--s5);border-radius:var(--r-full);
  background:var(--primary);border:2px solid var(--surface);box-shadow:var(--sha-sm);cursor:pointer;
}
.chr-slider::-moz-range-thumb{
  width:var(--s5);height:var(--s5);border-radius:var(--r-full);
  background:var(--primary);border:2px solid var(--surface);cursor:pointer;
}
.compare-skipped{
  border:1px solid var(--border);border-radius:var(--r-lg);background:var(--surface);
  padding:var(--s3) var(--s4);display:none;color:var(--muted);font-size:var(--xs);
}
.compare-skipped strong{color:var(--text)}
.compare-agreement{
  border:1px solid var(--border);border-radius:var(--r-xl);background:var(--surface);
  padding:var(--s4) var(--s5);display:none;flex-direction:column;gap:var(--s3);
}
.compare-chart-wrap{
  border:1px solid var(--border);border-radius:var(--r-xl);background:var(--surface);
  padding:var(--s4) var(--s5);display:none;width:100%;box-sizing:border-box;
}
.compare-chart-title{font-size:var(--sm);font-weight:800;margin-bottom:var(--s3)}
.compare-chart-title:not(:first-child){margin-top:var(--s4)}
.compare-chart-wrap canvas{display:block;width:100%;box-sizing:border-box;touch-action:none}
.compare-chart-legend{display:flex;gap:var(--s4);flex-wrap:wrap;margin-top:var(--s3)}
.mcl-item{display:flex;align-items:center;gap:var(--s2);font-size:var(--xs);color:var(--muted)}
.mcl-dot{width:var(--s3);height:var(--s3);border-radius:var(--r-full);flex-shrink:0}
.agree-title{font-size:var(--sm);font-weight:800}
.agree-note{font-size:var(--xs);color:var(--muted)}
.agree-row{display:flex;align-items:center;gap:var(--s3);font-size:var(--xs)}
.agr-lbl{width:96px;flex-shrink:0;color:var(--text);font-weight:700}
.agr-spread{width:64px;flex-shrink:0;text-align:right;white-space:nowrap}
.agr-avg{width:96px;flex-shrink:0;text-align:right;white-space:nowrap;color:var(--muted)}
.agree-bar-wrap{flex:1;height:var(--s2);background:var(--surface2);border-radius:var(--r-full);overflow:hidden}
.agree-bar{height:100%;border-radius:var(--r-full);transition:width var(--tr)}
.agree-good{background:var(--green)}
.agree-ok{background:var(--gold)}
.agree-poor{background:var(--err)}
.compare-card{
  border:1px solid var(--border);border-radius:var(--r-xl);background:var(--surface);
  border-left:var(--s1) solid var(--model-col,var(--border));
  padding:var(--s4);box-shadow:0 2px 8px rgba(40,37,29,.07);
}
.compare-model-row{display:flex;align-items:center;gap:var(--s2);flex-wrap:nowrap;margin-bottom:var(--s3);min-width:0}
.compare-model-main{display:flex;align-items:center;gap:var(--s2);flex-wrap:nowrap;min-width:0}
.compare-model{font-size:var(--base);font-weight:800;color:var(--model-col,var(--text));white-space:nowrap;flex:0 0 auto}
.compare-badge{
  font-size:var(--xs);color:var(--model-col,var(--muted));text-transform:uppercase;letter-spacing:.06em;
  border:1px solid var(--model-col,var(--border));border-radius:var(--r-full);padding:var(--s1) var(--s2);white-space:nowrap;flex:0 0 auto;
}
.compare-meta{display:flex;flex-wrap:nowrap;gap:var(--s2);font-size:var(--xs);color:var(--muted);min-width:0;overflow:hidden}
.compare-meta span{border:1px solid var(--model-col,var(--border));border-radius:var(--r-full);padding:var(--s1) var(--s2);background:var(--surface2);white-space:nowrap}
.compare-meta strong{color:var(--model-col,var(--text));font-weight:800}
.compare-data-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--s2)}
.compare-data-cell{
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:var(--s1);
  padding:var(--s3) var(--s2);background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--r-md);text-align:center;min-height:var(--s12);
}
.compare-data-val{font-size:var(--lg);font-weight:800;color:var(--text);line-height:1.1}
.compare-data-label{font-size:var(--xs);color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.compare-cell-rain{border-color:var(--blue)}
.compare-cell-wave{border-color:var(--green)}
.wind-speed-val{color:var(--wind-col,var(--text));font-weight:900}
.pcard .wind-speed-val{
  display:inline-flex;align-items:center;border-radius:999px;padding:1px 7px;margin:0 1px;
  background:rgba(255,255,255,.92);border:1px solid rgba(255,255,255,.35);
  text-shadow:none;
}
.compare-val-rain{color:var(--blue)}
.compare-val-wave{color:var(--green)}
.compare-card-note{font-size:var(--xs);color:var(--muted);margin-top:var(--s3)}
.compare-period{border-top:1px solid var(--motion);padding:var(--s2) 0}
.compare-period:first-of-type{border-top:none}
.compare-period-title{font-size:var(--xs);font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.compare-period-main{font-size:var(--sm);font-weight:700;margin-top:2px}
.compare-period-sub{font-size:var(--xs);color:var(--muted);margin-top:1px}
.field-source{font-size:var(--xs);color:var(--muted);font-weight:600;margin-left:var(--s1)}
.hybrid-note{font-size:var(--xs);color:var(--muted);margin-top:var(--s2);line-height:1.4}
.f-header{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r-xl);
  padding:var(--s4) var(--s5);box-shadow:0 1px 2px rgba(40,37,29,.06);
}
.f-venue{font-size:var(--lg);font-weight:700;letter-spacing:-.02em}
.f-date{font-size:var(--sm);color:var(--muted);margin-top:var(--s1)}
.f-meta{font-size:var(--xs);color:var(--muted);margin-top:var(--s2)}
.f-note{font-size:var(--sm);color:var(--muted);margin-top:var(--s2)}

.daily-card{
  grid-column:1/-1;
  background:linear-gradient(150deg,#f7f4ee,#e5e0d8);
  border:1px solid var(--primary);border-radius:var(--r-xl);
  box-shadow:0 8px 24px rgba(40,37,29,.10);overflow:hidden;
  -webkit-print-color-adjust:exact;print-color-adjust:exact;
}
.daily-top{
  background:linear-gradient(135deg,#2b5f91,#26384f);
  color:#fff;padding:var(--s5);display:grid;grid-template-columns:1fr auto;gap:var(--s4);
}
.daily-kicker{font-size:10px;text-transform:uppercase;letter-spacing:.08em;opacity:.78;font-weight:700}
.daily-title{font-size:2.15rem;font-weight:750;letter-spacing:-.045em;margin-top:var(--s1)}
.daily-sub{font-size:var(--sm);line-height:1.45;opacity:.86;margin-top:var(--s2)}
.boat-name{color:var(--inv)}
.daily-badge{
  justify-self:end;align-self:start;border:1px solid rgba(255,255,255,.28);
  border-radius:var(--r-md);padding:7px 10px;background:rgba(255,255,255,.08);
  text-align:left;min-width:0;white-space:nowrap;
}
.run-main{font-size:var(--sm);font-weight:800;letter-spacing:.01em}
.run-sub{font-size:var(--xs);opacity:.78;margin-top:2px}
.run-sub strong{font-weight:800;opacity:1}
.daily-note{font-size:var(--sm);line-height:1.45;opacity:.86;margin-top:var(--s2)}
.daily-subtle{opacity:.70}
.daily-detail{background:#fff;padding:var(--s4) var(--s5);border-top:1px solid var(--primary)}
.daily-detail-list{display:flex;flex-direction:column;gap:var(--s3)}
.daily-detail-row{
  display:flex;align-items:flex-start;gap:var(--s2);font-size:var(--sm);line-height:1.45;color:var(--text);
}
.daily-detail-row .row-icon{flex:0 0 17px;color:var(--muted);margin-top:2px;opacity:1}
.daily-detail-row .row-icon svg{stroke:var(--muted)}
.daily-detail-row strong{font-weight:600}
.daily-detail .cape-pill{
  background:var(--motion);border:1px solid var(--border);color:inherit;
}
.daily-source{
  font-size:var(--xs);color:var(--muted);margin-top:var(--s3);padding-top:var(--s3);
  border-top:1px solid var(--motion);line-height:1.4;
}
.brief-strip.window-only{grid-template-columns:1fr}
.daily-context{
  display:flex;align-items:center;gap:var(--s3);flex-wrap:wrap;
  font-size:var(--sm);opacity:.72;margin-top:var(--s1);
}
.daily-context span{white-space:nowrap}
.daily-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--primary);border-top:1px solid var(--primary)}
.metric{background:#fff;padding:var(--s4);min-height:82px}
.metric-label{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);font-weight:700}
.metric-value{font-size:1.45rem;font-weight:700;letter-spacing:-.03em;margin-top:var(--s2)}
.metric-value.long{font-size:1.05rem;line-height:1.25;letter-spacing:-.01em}
.metric-value.single{font-size:1.25rem;line-height:1.2;white-space:nowrap}
.metric-detail{font-size:var(--xs);color:var(--muted);line-height:1.35;margin-top:var(--s1)}
.brief-strip{
  display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--primary);
  border-top:1px solid var(--primary);
}
.brief-item{background:#fff;padding:var(--s3) var(--s4)}
.brief-label{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);font-weight:700}
.brief-value{font-size:var(--sm);font-weight:600;margin-top:2px}
.day-row-title{
  display:flex;align-items:baseline;gap:var(--s2);
  margin-top:var(--s2);font-size:1.15rem;font-weight:800;color:#102f38;letter-spacing:-.02em;
}
.day-row-title span{font-size:var(--xs);font-weight:600;color:var(--muted);letter-spacing:0}

.pcard{
  border-radius:var(--r-xl);padding:var(--s4) var(--s5);color:#fff;
  box-shadow:0 4px 12px rgba(40,37,29,.12);
  -webkit-print-color-adjust:exact;print-color-adjust:exact;
}
.pcard.c0{background:linear-gradient(160deg,#4a78be,#5b90d8)}
.pcard.c1{background:linear-gradient(160deg,#3f7db2,#5794c8)}
.pcard.c2{background:linear-gradient(160deg,#5579b8,#6e93cc)}
.pcard.c3{background:linear-gradient(160deg,#4e6ea8,#6584be)}
.pcard.c4{background:linear-gradient(160deg,#3a5898,#4f74b8)}
.pcard.c5{background:linear-gradient(160deg,#102d57,#203f73)}
.pt-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:var(--s3)}
.pt-name{font-size:var(--base);font-weight:700}
.pt-time{font-size:var(--xs);opacity:.85}
.frow{
  font-size:var(--sm);line-height:1.5;padding:var(--s1) 0;border-top:1px solid rgba(255,255,255,.15);
  display:flex;align-items:flex-start;gap:var(--s2);
}
.frow:first-of-type{border-top:none;padding-top:0}
.row-icon{
  width:17px;height:17px;flex:0 0 17px;opacity:.72;margin-top:2px;
}
.row-icon svg{display:block;width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.frow strong{font-weight:600}
.cape-pill{
  display:inline-flex;align-items:center;border-radius:999px;padding:1px 7px;margin-left:2px;
  background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.24);font-weight:700;
}
.cape-low{color:#d9e2ea}.cape-watch{color:#f6d98b}.cape-active{color:#f2a36e}.cape-high{color:#ff8f8f}
.f-footer{font-size:var(--xs);color:var(--muted);text-align:center;padding-top:var(--s2)}

.empty{padding:var(--s8);text-align:center;color:var(--muted);font-size:var(--sm)}
.err{
  padding:var(--s4);border:1px solid #ef4444;border-radius:var(--r-lg);
  background:rgba(239,68,68,.08);color:#991b1b;font-size:var(--sm);
}

@page{size:A4 landscape;margin:8mm}
@media print{
  aside,header,.toolbar,.sidebar-panel,.sidebar-resizer,.no-print{display:none!important}
  .app-body{grid-template-columns:1fr!important}
  body{display:block;height:auto;overflow:visible}
  main{overflow:visible}
  .preview-area{overflow:visible;padding:0}
  .forecast-doc{max-width:none;display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
  .f-header{grid-column:1/-1}
  .daily-card{grid-column:1/-1}
  .pcard{break-inside:avoid;page-break-inside:avoid}
  html,body{-webkit-print-color-adjust:exact;print-color-adjust:exact}
}
@media(max-width:900px){
  body{height:auto;overflow:auto}
  .app-body{grid-template-columns:1fr;grid-template-rows:auto 1fr}
  .sidebar-panel{border-right:none;border-bottom:1px solid var(--motion)}
  .sidebar-resizer{display:none}
  aside{max-height:55vh}
  .daily-top,.brief-strip{grid-template-columns:1fr}
  .team-period-grid{grid-template-columns:1fr}
  .compare-grid{grid-template-columns:1fr}
  .daily-badge{justify-self:start}
}
</style>
</head>
<body>

<header class="no-print">
  <div style="display:flex;align-items:center;gap:var(--s3)">
    <button type="button" class="icon-btn" id="sidebarToggle" onclick="toggleSidebar()" title="Toggle setup panel" aria-label="Toggle setup panel">
      <svg id="sidebarToggleIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
    </button>
    <div>
      <div class="logo-name">Layla</div>
      <div class="logo-sub">Navigation Brief · 2026 IMA Maxi Europeans</div>
    </div>
  </div>
  <div class="hdr-actions">
    <button type="button" class="btn btn-ghost" onclick="window.print()">Print A4</button>
  </div>
</header>

<div class="app-body">
<div class="sidebar-panel no-print" id="sidebarPanel">
<aside>
  <section>
    <div class="sec-label">Event</div>
