function trendSummaryText(trend){
  return (trend?.lines || []).map(line => line.text).filter(Boolean).join('\n');
}

function trendSummary(idxs){
  const empty = {
    lines: [{ type: 'data', html: 'Load forecast data to generate trend lines.', text: 'Load forecast data to generate trend lines.' }],
    startTwd: null, endTwd: null, twdDelta: null, startTws: null, endTws: null, twsDelta: null,
  };
  if(!idxs.length) return empty;

  const startTwd = windDirMean(forecastData.twd, [idxs[0]]);
  const endTwd = windDirMean(forecastData.twd, [idxs[idxs.length - 1]]);
  const twdDelta = signedAngularDelta(startTwd, endTwd);
  const startTws = forecastData.tws[idxs[0]];
  const endTws = forecastData.tws[idxs[idxs.length - 1]];
  const twsDelta = startTws == null || endTws == null ? null : endTws - startTws;

  const lines = [];
  const windowSpan = hourRangeAtIndices(idxs[0], idxs[idxs.length - 1]);

  const twdShifts = detectBigShifts(idxs, 'twd', TREND_BIG_TWD_DEG, 3, true)
    .sort((a, b) => Math.abs(b.delta) - Math.abs(a.delta))
    .slice(0, TREND_MAX_PER_FIELD);
  twdShifts.forEach(shift => lines.push(formatTwdShiftLine(shift)));

  const twsShifts = detectBigShifts(idxs, 'tws', TREND_BIG_TWS_KT, 3, false)
    .sort((a, b) => Math.abs(b.delta) - Math.abs(a.delta))
    .slice(0, TREND_MAX_PER_FIELD);
  twsShifts.forEach(shift => lines.push(formatTwsShiftLine(shift)));

  if(!lines.length){
    const twdMean = windDirMean(forecastData.twd, idxs);
    const twsLo = minValue(forecastData.tws, idxs);
    const twsHi = maxValue(forecastData.tws, idxs);
    const twdNote = twdMean == null ? 'TWD steady' : `TWD steady · ${degToDir(twdMean)} ${Math.round(twdMean)}°`;
    const twsNote = twsLo == null ? 'TWS steady' : `TWS steady · ${fmtRange(twsLo, twsHi, ' kt')}`;
    lines.push({
      type: 'wind',
      html: `${escapeHtml(twdNote)} · ${escapeHtml(twsNote)} · <strong>${escapeHtml(windowSpan)}</strong>`,
      text: `${twdNote} · ${twsNote} · ${windowSpan}`,
    });
  }

  return {
    lines,
    text: trendSummaryText({ lines }),
    startTwd,
    endTwd,
    twdDelta,
    startTws,
    endTws,
    twsDelta,
  };
}

