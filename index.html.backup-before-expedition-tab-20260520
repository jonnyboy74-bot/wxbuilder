  if(ms == null || isNaN(Number(ms))) return '';
  return `${Number(ms).toFixed(1)} ms`;
}

function compareResolutionText(resolution){
  if(!resolution) return '';
  const clean = String(resolution)
    .replace(/^File resolution\s+/i, '')
    .replace(/^Resolution\s+/i, '')
    .trim();
  if(!clean || clean.toLowerCase() === 'unknown') return '';
  return clean;
}

function runScheduleForModel(model){
  const id = resolveOpenMeteoModelId(model);
  if(id.includes('ecmwf') || id.includes('ifs') || id.includes('aifs')) return [0, 6, 12, 18];
  return [0, 6, 12, 18];
}

function formatDuration(ms){
  const totalMin = Math.max(0, Math.round(ms / 60000));
  const h = Math.floor(totalMin / 60);
  const m = totalMin % 60;
  return `${h}h ${String(m).padStart(2, '0')}m`;
}

function runBadgeInfo(modelLabel){
  const now = new Date();
  if(forecastMeta?.source === 'Squid GRIB'){
    const run = formatRunTime(forecastMeta);
    const parts = [];
    if(forecastMeta.loadedAt) parts.push(`GRIB loaded ${formatLoadedTime(forecastMeta.loadedAt)}`);
    if(forecastMeta.omSupplementRun) parts.push(`OM supplement ${forecastMeta.omSupplementRun}`);
    return {
      primary: run ? `${modelLabel} · run ${run}` : modelLabel,
      secondary: parts.join(' · ') || `Loaded ${now.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' })}`,
    };
  }
  const model = forecastMeta?.model || document.getElementById('briefingModel')?.value || 'best';
  const schedule = runScheduleForModel(model);
  let runHour = null;

  if(forecastMeta?.refTime != null){
    runHour = Math.floor(parseInt(String(forecastMeta.refTime).padStart(4, '0'), 10) / 100);
  } else {
    const utcHour = now.getUTCHours();
    runHour = schedule.filter(h => h <= utcHour).pop();
    if(runHour == null) runHour = schedule[schedule.length - 1];
  }

  return {
    primary: `${modelLabel} · run ${String(runHour).padStart(2, '0')}:00z`,
    secondary: `Issued at ${now.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' })}`,
  };
}

