function saveCustomVenue(){
  const label = document.getElementById('venueInput').value.trim();
  if(!label){ alert('Enter a location name first (e.g. Sorrento Race Area).'); return; }
  const lat = parseFloat(document.getElementById('latInput').value);
  const lon = parseFloat(document.getElementById('lonInput').value);
  if(isNaN(lat) || isNaN(lon)){ alert('Set valid latitude and longitude.'); return; }
  const value = venueValue(lat, lon, label);
  let venues = getSavedVenues();
  if(editingVenueId){
    const idx = venues.findIndex(v => v.id === editingVenueId);
    if(idx >= 0){
      venues[idx] = { ...venues[idx], lat, lon, label, value };
      setSavedVenues(venues);
      refreshVenuePresetSelect(value);
      editingVenueId = null;
      updateSaveVenueBtn();
      if(venueManageOpen) renderVenueManageList();
      setStatus('green', `Updated location: ${label}`);
      return;
    }
    editingVenueId = null;
    updateSaveVenueBtn();
  }
  const duplicate = venues.find(v => v.value === value);
  if(duplicate){
    refreshVenuePresetSelect(value);
    setStatus('yellow', `Location already saved: ${label}`);
    return;
  }
  venues.push({
    id: 'venue-' + Date.now() + '-' + Math.random().toString(36).slice(2, 7),
    lat, lon, label, value,
  });
  setSavedVenues(venues);
  refreshVenuePresetSelect(value);
  if(venueManageOpen) renderVenueManageList();
  setStatus('green', `Saved location: ${label}`);
}

