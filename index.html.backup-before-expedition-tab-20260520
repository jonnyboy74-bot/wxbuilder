    || !seriesHasValues(forecastData.uv);
}

async function fetchOpenMeteoEcmwfSupplement(lat, lon, targetDate){
  const dateParam = `&start_date=${targetDate}&end_date=${targetDate}`;
  const url = 'https://api.open-meteo.com/v1/ecmwf'
    + `?latitude=${lat}&longitude=${lon}`
    + '&hourly=temperature_2m,weathercode,cape,uv_index,precipitation'
    + '&timezone=Europe%2FRome&wind_speed_unit=kn'
    + `&models=${HYBRID_OM_MODEL_ID}${dateParam}`;
  const [res, metaJson] = await Promise.all([
    fetch(url),
    fetchOpenMeteoRunMeta(HYBRID_OM_MODEL_ID),
  ]);
  if(!res.ok) throw new Error(`Open-Meteo ECMWF supplement HTTP ${res.status}`);
  const data = await res.json();
  if(data.error) throw new Error(data.reason || 'Open-Meteo ECMWF supplement error');
  const hours = (data.hourly?.time || []).map(t => parseInt(t.split('T')[1], 10));
  return {
    hours,
    cape: data.hourly?.cape || [],
    rain: data.hourly?.precipitation || [],
    uv: data.hourly?.uv_index || [],
    temp: data.hourly?.temperature_2m || [],
    wmo: data.hourly?.weathercode || [],
    run: formatUnixUtcRun(metaJson?.last_run_initialisation_time),
    apiLive: formatUnixUtcRun(metaJson?.last_run_availability_time),
  };
}

function alignSupplementToForecast(supplement){
  const hourMap = new Map();
  supplement.hours.forEach((h, i) => hourMap.set(h, i));
  const pick = key => forecastData.hours.map(h => {
    const idx = hourMap.get(h);
    return idx == null ? null : (supplement[key]?.[idx] ?? null);
  });
  return {
    cape: pick('cape'),
    rain: pick('rain'),
    uv: pick('uv'),
    temp: pick('temp'),
    wmo: pick('wmo'),
  };
}

async function supplementForecastFromOpenMeteo(options = {}){
  const { silent = false, auto = false } = options;
  if(!gribNeedsOpenMeteoSupplement()){
    if(!silent) setStatus('yellow', 'GRIB already has CAPE/rain/UV or no GRIB brief loaded.');
    return false;
  }
  const lat = parseFloat(document.getElementById('latInput').value);
  const lon = parseFloat(document.getElementById('lonInput').value);
  if(isNaN(lat) || isNaN(lon)){
    if(!silent) setStatus('red', 'Set location before Open-Meteo supplement.');
    return false;
  }
  const targetDate = document.getElementById('fDate').value || new Date().toISOString().split('T')[0];
  if(!silent) setStatus('yellow', 'Fetching Open-Meteo ECMWF supplement…');
  try {
    const supplement = await fetchOpenMeteoEcmwfSupplement(lat, lon, targetDate);
    const aligned = alignSupplementToForecast(supplement);
    const label = 'Open-Meteo ECMWF';
    forecastMeta.fieldSources = forecastMeta.fieldSources || {};
    let merged = 0;
    if(!seriesHasValues(forecastData.cape) && seriesHasValues(aligned.cape)){
      forecastData.cape = aligned.cape;
      forecastMeta.fieldSources.cape = label;
      merged++;
    }
    if(!seriesHasValues(forecastData.rain) && seriesHasValues(aligned.rain)){
      forecastData.rain = aligned.rain;
      forecastMeta.fieldSources.rain = label;
      forecastMeta.rainMode = forecastMeta.rainMode || 'accum';
      merged++;
    }
    if(!seriesHasValues(forecastData.uv) && seriesHasValues(aligned.uv)){
      forecastData.uv = aligned.uv;
      forecastMeta.fieldSources.uv = label;
      merged++;
    }
    if(!seriesHasValues(forecastData.temp) && seriesHasValues(aligned.temp)){
      forecastData.temp = aligned.temp;
      forecastMeta.fieldSources.temp = label;
      merged++;
    }
    if(!seriesHasValues(forecastData.wmo) && seriesHasValues(aligned.wmo)){
      forecastData.wmo = aligned.wmo;
      forecastMeta.fieldSources.sky = label;
      merged++;
    }
    forecastMeta.omSupplementRun = supplement.run || '';
    forecastMeta.omSupplementLive = supplement.apiLive || '';
    if(!merged){
      if(!silent) setStatus('yellow', 'Open-Meteo ECMWF had no usable supplement fields for this date.');
      return false;
    }
    const stamp = new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    const msg = auto
      ? `GRIB brief loaded · supplemented ${merged} field(s) from Open-Meteo ECMWF`
      : `Supplemented ${merged} field(s) from Open-Meteo ECMWF · ${stamp}`;
    setStatus('green', msg);
    renderBrief();
    updateSupplementButtonVisibility();
    return true;
  } catch(e){
    if(!silent) setStatus('red', `Open-Meteo supplement failed: ${e.message}`);
    return false;
  }
}
