</aside>
<div class="sidebar-resizer" id="sidebarResizer" title="Drag to resize"></div>
</div>

<main>
  <div class="toolbar no-print">
    <h2>Period brief</h2>
    <div class="tab-bar">
      <button type="button" class="tab-btn active" id="briefTabBtn" onclick="switchMainTab('brief')">Briefing</button>
      <button type="button" class="tab-btn" id="compareTabBtn" onclick="switchMainTab('compare')">Model comparison</button>
