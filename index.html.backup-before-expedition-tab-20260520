function formatCoord(lat, lon){
  if(lat == null || lon == null || isNaN(lat) || isNaN(lon)) return '';
  const la = Number(lat);
  const lo = Number(lon);
  return `${Math.abs(la).toFixed(3)}°${la >= 0 ? 'N' : 'S'} ${Math.abs(lo).toFixed(3)}°${lo >= 0 ? 'E' : 'W'}`;
}

function formatRunTime(meta){
  if(!meta?.refDate || !meta?.refTime) return '';
  const d = String(meta.refDate);
  const t = String(meta.refTime).padStart(4, '0');
  if(d.length !== 8) return '';
  return `${d.slice(0,4)}-${d.slice(4,6)}-${d.slice(6,8)} ${t.slice(0,2)}${t.slice(2)}Z`;
}

function formatLoadedTime(iso){
  if(!iso) return '';
  const d = new Date(iso);
  if(isNaN(d)) return '';
  return d.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' });
}

